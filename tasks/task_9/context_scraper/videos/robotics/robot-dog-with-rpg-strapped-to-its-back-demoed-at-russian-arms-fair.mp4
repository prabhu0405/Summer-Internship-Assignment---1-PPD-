<script src="https://js.chargebee.com/v2/chargebee.js" id="chargebee-js-js"></script>
<script id="chargebee-js-js-after">
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('cb-user-form');

    const cbUserModal = document.getElementById('cb-user-modal');



    // Check if form exists before proceeding
    if (form) {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            let firstName = document.getElementById('cb-first-name').value.trim();
        let lastName = document.getElementById('cb-last-name').value.trim();
        let email = document.getElementById('cb-email').value.trim();
        let errorMsg = document.getElementById('cb-error-msg');


        let userData = [firstName, lastName, email];
        localStorage.setItem('userData', JSON.stringify(userData));

        // Reset error
        errorMsg.style.display = 'none';
        errorMsg.textContent = '';

        // Validation
        if (firstName === '' || lastName === '' || email === '') {
            errorMsg.textContent = 'Please fill in all fields.';
            errorMsg.style.display = 'block';
            return;
        }

        let emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailPattern.test(email)) {
            errorMsg.textContent = 'Please enter a valid email address.';
            errorMsg.style.display = 'block';
            return;
        }

            if(cbUserModal){
            cbUserModal.style.display = 'none';
            }

            let chargebeeInstance;
            let site_name = cbPluginVars.siteName;

            try {
                // Validate site_name
                if (!site_name || typeof site_name !== 'string' || site_name.trim() === '') {
                    console.warn('Invalid or empty site_name, using fallback');
                }

                // Construct dynamic domain using string concatenation to avoid PHP interpolation
                const domain = 'https://' + site_name + '.chargebee.com';

                chargebeeInstance = Chargebee.init({
                    site: site_name,
                    domain: domain
                });
            } catch (error) {
                console.error('Error initializing Chargebee:', error);
                alert('Failed to initialize Chargebee. Please try again later.');
                return;
            }
            // Resume after login if needed
            const savedPlanId = localStorage.getItem('cb_selected_plan_id');
            let savedPurchaseType = localStorage.getItem('cb_selected_purchase_type');

            if (savedPlanId) {

                openChargebeeCheckout(chargebeeInstance, savedPlanId, email, firstName, lastName, cbUserData.back_url, savedPurchaseType);
                localStorage.removeItem('cb_selected_plan_id');
            }

                async function sha256(input) {
                    const encoder = new TextEncoder();
                    const data = encoder.encode(input.trim().toLowerCase());
                    const hashBuffer = await crypto.subtle.digest('SHA-256', data);
                    const hashArray = Array.from(new Uint8Array(hashBuffer));
                    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
                }

                async function getUserData() {
                    let savedArray = JSON.parse(localStorage.getItem('userData')) || [];
                    let firstName = savedArray[0] || '';
                    let lastName  = savedArray[1] || '';
                    let email     = savedArray[2] || '';

                    return {
                        'hash_email': email ? await sha256(email) : '',
                        'hash_firstname': firstName ? await sha256(firstName) : '',
                        'hash_lastname': lastName ? await sha256(lastName) : '',
                    };
                }


            function openChargebeeCheckout(instance, planId, email, name, lastname, backUrl, savedPurchaseType) {
                instance.openCheckout({
                    hostedPage: function () {
                        return fetch(cbPluginVars.pluginUrl + '/create-checkout.php'
                            + '?plan_id='        + encodeURIComponent(planId)
                            + '&purcahse_type='  + encodeURIComponent(savedPurchaseType)
                            + '&email='          + encodeURIComponent(email)
                            + '&name='           + encodeURIComponent(name)
                            + '&lastname='       + encodeURIComponent(lastname)
                            + '&back_url='       + encodeURIComponent(backUrl)
                            + '&_wpnonce='       + encodeURIComponent(cbPluginVars.cbNonce))
                            .then(response => response.json())
                            .then(data => {
                                if (data.hostedPage) {
                                    return data.hostedPage;
                                } else {
                                    throw new Error('Hosted page URL not found in response');
                                }
                            })
                            .catch(error => {
                                console.error('Error fetching hosted page:', error);
                                alert('An error occurred while creating the checkout page.');
                            });
                    },
                    success: function (hostedPage) {
                    let savedPurchaseType = localStorage.getItem('cb_selected_purchase_type');
                    if (savedPurchaseType == 'charge') {
                        const chargebemodal = document.getElementById('cb-container');
                        if (chargebemodal) {
                            chargebemodal.classList.add('cb-hide');
                        }

                        const modal = document.getElementById('tyModal');
                        const tymodal = document.getElementsByClassName('ty-modal-overlay')[0];
                        if (tymodal) {
                            tymodal.style.display = 'flex';
                        }
                        if (modal) {
                            modal.classList.remove('ty-hidden');
                            modal.classList.add('ty-show');
                        }

                        const planId   = localStorage.getItem('cb_selected_plan_id_purchase_event');
                        const planName = localStorage.getItem('cb_selected_plan_name');
                        const planPrice = localStorage.getItem('cb_selected_plan_price');

                        if (typeof fbq !== 'undefined') {
                            getUserData().then(userdata => {
                                const eventData = {
                                    'content_ids': [planId],
                                    'content_type': 'product',
                                    'contents': [{
                                        'id': planId,
                                        'quantity': 1,
                                        'item_price': planPrice,
                                        'name': planName || 'VICE Subscription'
                                    }],
                                    'currency': 'USD',
                                    'value': planPrice,
                                    ...userdata
                                };

                                // ✅ Send purchase event
                                fbq('track', 'Purchase', eventData);

                                // ✅ Clear localStorage
                                localStorage.removeItem('payment_status');
                                localStorage.removeItem('cb_selected_plan_id_purchase_event');
                                localStorage.removeItem('cb_selected_plan_name');
                                localStorage.removeItem('cb_selected_plan_price');
                                localStorage.removeItem('userData');
                            });
                        }
                    }

                        if (hostedPage && savedPurchaseType!=='charge') {
                            // Create and login the user first
                            fetch(cbPluginVars.pluginUrl + '/user-creation-login.php', {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/x-www-form-urlencoded'
                                },
                                body: new URLSearchParams({
                                    email: email,
                                    first_name: name || '',
                                    last_name: lastname
                                })
                            })
                                .then(res => res.json())
                                .then(data => {
                                    if (data.success) {
                                        localStorage.setItem('payment_status', 'succeeded');
                                        // Redirect to the hosted page after successful login
                                     window.location.reload();

                                    } else {
                                        alert('⚠️ Login error: ' + (data.error || 'Unknown error'));
                                    }
                                })
                                .catch(err => {
                                    console.error('❌ Login request failed', err);
                                    alert('User login failed.');
                                });
                        }
                    }
                    ,
                    close: function () {
                    }
                });
            }
        });
    }

});

        
//# sourceURL=chargebee-js-js-after
</script>
