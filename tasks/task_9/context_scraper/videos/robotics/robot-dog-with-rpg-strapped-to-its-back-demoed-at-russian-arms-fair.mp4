<!-- custom-ads entry #3 -->
<script type='text/javascript'>
document.addEventListener('DOMContentLoaded', function () {
    // Ad selectors
    const adSelectors = [

        '.lngtd-dynamic-inarticle',
        '.lngtd-dynamic-rr',
        '.vice_D_leaderboard_index',
        '.vice_M_leaderboard_index',
        '.vice_M_leaderboard',
        '#consent-module-mspa',
        '#consent-module-mspa',
        '.wp-block-savage-platform-primis-video__heading',
        '#primis_container_div',
        '#vice_end_of_article',
        '.wp-block-savage-platform-primis-video',
        '.ai-content',
        '#htl-ad-container',
        '.raptive-ad',
        '.ksc-container',
        '.lngtd-dynamic-ad-container',
        '.lngtd-dyn-ph',
        '.sci-topbanner',
        '.code-block',
        '.ksl-adv-lbl',
        '.ai-viewport-1',
        '.ai-viewport-2',
        '.ai-viewport-3',
        '#mobile-adhesion-ad',
        '.lngtd-ad-wrapper-styles',
        '.ksc-in-con'
    ];

    // Declare the adRemovalInterval outside the removeAds function
    let adRemovalInterval;

    // Function to remove ads
    function removeAds() {
        let allAdsRemoved = true;

        // Remove ads from the adSelectors list
        adSelectors.forEach(selector => {
            document.querySelectorAll(selector).forEach(el => el.remove());
        });

        // Remove ad scripts by their IDs
        const adScriptIds = ['htl-bid-script', 'raptive-script', 'primis-script-handle'];
        adScriptIds.forEach(id => {
            const script = document.getElementById(id);
            if (script) script.remove();
        });

        // Remove additional ad-related elements
        document.querySelectorAll('.ai-dynamic, .ai-block, .adsbygoogle, [id^="google_ads_iframe"]').forEach(el => el.remove());

        // Check if any ads still exist
        adSelectors.forEach(selector => {
            if (document.querySelectorAll(selector).length > 0) {
                allAdsRemoved = false;
            }
        });

        // Remove specific ad-related scripts
        const scriptsToRemove = [
            "https://standout-cdn.kargo.com/js/rh.min.js",
            "https://lngtd.com/vice.js",
            "https://socialcanvas-cdn.kargo.com/js/ksopb.js",
            "https://standout-cdn.kargo.com/js/rh.min.js",
            "https://srv.tunefindforfans.com/fruits/mangos.js",
            "//b-code.liadm.com/b-02qi.min.js",
            "https://socialcanvas-cdn.kargo.com/js/ksopb.js"
        ];

        scriptsToRemove.forEach(src => {
            const scripts = document.querySelectorAll(`script[src="${src}"]`);
            scripts.forEach(script => script.remove());
        });

        if (allAdsRemoved) {
            console.log("All ads removed");
            clearInterval(adRemovalInterval); // Stop the interval once all ads are removed
        }
    }

    // Make a fetch request to check if ads should be disabled
    fetch('/wp-admin/admin-ajax.php?action=check_ads', {
        method: 'GET',
        credentials: 'same-origin'
    })
    .then(response => response.json())
    .then(data => {
        // Check if ads should be disabled
        if (data.disable_ads) {
            console.log("User logged in, Ads removal started");

            // Run the removeAds function after receiving the correct condition
            removeAds();

            // Start MutationObserver and repeated checks after confirming disable_ads is true
            startAdObserver();

            // Optional: Repeatedly check to make sure new ads are removed if they appear
            adRemovalInterval = setInterval(removeAds, 2000); // Now defined before use

            let count = 0;
            const maxRemovals = 100;
            const intervalId = setInterval(function() {
                removeAds();
                count++;
                if (count >= maxRemovals) {
                    clearInterval(intervalId);
                }
            }, 5000);

			document.body.classList.add('hide-ads');
        } else {
            // If ads shouldn't be disabled, ensure ads are visible
            console.log("Ads not removed");
            adSelectors.forEach(selector => {
                document.querySelectorAll(selector).forEach(el => el.style.visibility = 'visible');
            });
        }
    })
    .catch(err => console.error('Error checking ads:', err));

    // Function to initialize MutationObserver after AJAX success
    function startAdObserver() {
        // MutationObserver to watch for dynamically added ads
        const observer = new MutationObserver(function(mutationsList, observer) {
            // Loop through all mutations that just occurred
            for(const mutation of mutationsList) {
                if (mutation.type === 'childList') {
                    // Check if any ads are added and remove them
                    adSelectors.forEach(selector => {
                        mutation.addedNodes.forEach(node => {
                            if (node.matches && node.matches(selector)) {
                                node.remove();
                            }
                        });
                    });
                }
            }
        });

        // Observer configuration
        const config = { childList: true, subtree: true };

        // Start observing the body for added nodes
        observer.observe(document.body, config);
    }
});
</script>
