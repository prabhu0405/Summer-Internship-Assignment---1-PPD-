<script type="text/javascript">
/*More from vice - article images adding anchor */
document.addEventListener('DOMContentLoaded', function () {
  const container = document.querySelector('.more-from-vice');

  if (!container) return;

  const posts = container.querySelectorAll('.wp-block-post');

  posts.forEach(function (post) {
    const titleLink = post.querySelector('.wp-block-post-title a');
    const featuredImage = post.querySelector('.wp-block-post-featured-image');

    if (titleLink && featuredImage && !featuredImage.querySelector('a')) {
      const imageContent = featuredImage.innerHTML;

      const link = document.createElement('a');
      link.href = titleLink.href;
      link.innerHTML = imageContent;

      featuredImage.innerHTML = '';
      featuredImage.appendChild(link);
    }
  });
});
</script>
