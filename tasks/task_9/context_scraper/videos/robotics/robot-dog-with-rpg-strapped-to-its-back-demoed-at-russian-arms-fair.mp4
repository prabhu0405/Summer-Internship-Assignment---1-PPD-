		    <script>
        document.addEventListener("DOMContentLoaded", function () {
            function handleLoginQueryParam() {
                const isLoginParam = localStorage.getItem('is_login');

                if (isLoginParam) {
                    const url = new URL(window.location.href);
                    url.searchParams.delete('is_login');
                    url.searchParams.append('is_login', isLoginParam);
                    localStorage.removeItem('is_login');
                    window.location.href = url.toString();
                }
            }

            handleLoginQueryParam();
        });
    </script>
        <style>
        a.login-btn.openid-login-link {
            color: #909090 !important;
            font-weight: var(--wp--custom--typography--font-weight--bold);
            text-transform: uppercase;
            line-height: 1.5;
        }

        a.login-btn.openid-login-link:hover {
            color: white !important;
        }

        li button {
            padding-top: 0 !important;
            padding-bottom: 0 !important;
        }

        li button span {
            color: #909090 !important;
            text-transform: uppercase;
            line-height: 1.5;
            font-weight: var(--wp--custom--typography--font-weight--bold) !important;
        }

        li button span:hover {
            color: white !important;
        }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const languageWrapper = document.querySelector('.wp-block-savage-platform-theme-language-picker');
            const footerMenu = document.querySelector('nav[data-location="footer"] ul#menu-footer');
            const ajaxUrl = "https://www.vice.com/wp-admin/admin-ajax.php";

            // ---------- Helper: Create Login Button ----------
            function createLoginButton(target, loginUrl, addAdFree = true) {
                // New Go Ad Free button, created only if addAdFree is true
                let adFreeBtn;
                if (addAdFree) {
                    adFreeBtn = document.createElement("button");
                    adFreeBtn.textContent = "Go Ad Free";
                    adFreeBtn.style.cssText = `
                    background: #fff;
                    color: #000;
                    border: none;
                    font-weight: bold;
                    cursor: pointer;
                    margin-right: 15px;
                    padding: 4px 16px;
                    border-radius: 4px;
                `;

                    adFreeBtn.addEventListener('click', () => {
                        if (typeof openModalFree === 'function') {
                            document.querySelector('.free-modal-container').style.display = 'block';
                            openModalFree();

                        }
                    });

                }

                const btnWrapper = document.createElement("button");
                btnWrapper.style.cssText = `
                background: transparent;
                border: none;
                outline: none;
                text-decoration: none;
                margin-right: 30px;
                font-weight: bold;
                cursor: pointer;
            `;

                const link = document.createElement('a');
                link.href = loginUrl;
                link.className = "login-btn openid-login-link";
                link.textContent = "Login / Sign Up";
                link.style.color = "#fff";
                link.style.textDecoration = "none";
                link.addEventListener('click', () => {
                    const timestampId = Date.now();
                    localStorage.setItem('is_login', timestampId);
                });

                btnWrapper.appendChild(link);

                if (target.tagName === 'UL') {
                    const li = document.createElement('li');

                    if (addAdFree) {
                        const adFreeWrapper = document.createElement("button");
                        adFreeWrapper.style.cssText = `
                        background: transparent;
                        border: none;
                        outline: none;
                        text-decoration: none;
                        margin-right: 15px;
                        font-weight: bold;
                        cursor: pointer;
                    `;
                        adFreeWrapper.appendChild(adFreeBtn);
                        li.appendChild(adFreeWrapper);
                    }

                    li.appendChild(btnWrapper);
                    target.appendChild(li);
                } else {
                    if (addAdFree) target.insertBefore(adFreeBtn, target.firstChild);
                    target.insertBefore(btnWrapper, target.firstChild.nextSibling);
                }
            }



            // ---------- Helper: Create Logout Button ----------
            function createLogoutButton(target) {
                const btnWrapper = document.createElement("button");
                btnWrapper.style.cssText = `
                background: transparent;
                border: none;
                outline: none;
                text-decoration: none;
                margin-right: 30px;
                font-weight: bold;
                cursor: pointer;
                color: #fff;
            `;

                const span = document.createElement("span");
                span.textContent = "Logout";
                span.style.textDecoration = "none";
                span.style.color = "#fff";

                btnWrapper.appendChild(span);
                btnWrapper.addEventListener('click', (e) => {
                    e.preventDefault();
                    btnWrapper.textContent = "Logging out...";
                    btnWrapper.disabled = true;

                    fetch(ajaxUrl + '?action=custom_logout', {
                        method: 'POST',
                        credentials: 'same-origin',
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded"
                        }
                    })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                window.location.href = 'https://identity.vice.com/if/flow/vice-logout/';
                            } else {
                                alert("Logout failed!");
                                btnWrapper.textContent = "Logout";
                                btnWrapper.disabled = false;
                            }
                        })
                        .catch(err => {
                            console.error("Logout error:", err);
                            btnWrapper.textContent = "Logout";
                            btnWrapper.disabled = false;
                        });
                });

                if (target.tagName === 'UL') {
                    const li = document.createElement('li');
                    li.appendChild(btnWrapper);
                    target.appendChild(li);
                } else {
                    target.insertBefore(btnWrapper, target.firstChild);
                }
            }
            // ---------- Determine User Membership Status ----------
            function createManageMembershipButton(target, status) {
                const btnWrapper = document.createElement("button");
                btnWrapper.style.cssText = `
                background: transparent;
                border: none;
                outline: none;
                text-decoration: none;
                margin-right: 30px;
                font-weight: bold;
                cursor: pointer;
                color: #fff;
            `;

                const span = document.createElement("span");
                span.textContent = "Manage Membership";
                span.style.textDecoration = "none";
                span.style.color = "#fff";

                btnWrapper.appendChild(span);
                btnWrapper.addEventListener('click', (e) => {
                    if (status === 'cb_active') {
                        window.location.href = "https://portal.vice.com/";
                    } else if (status === 'grrm_active') {
                        window.location.href = "https://payments.google.com/gp/w/home/subscriptionsandservices";
                    }
                });

                if (target.tagName === 'UL') {
                    const li = document.createElement('li');
                    li.appendChild(btnWrapper);
                    target.appendChild(li);
                } else {
                    target.insertBefore(btnWrapper, target.firstChild);
                }
            }

            // ---------- Determine Logged-in Status ----------
            const currentUrl = window.location.href;

            let formData = new FormData();
            formData.append('action', 'get_auth_buttons_json');
            formData.append('redirect_to', currentUrl);

            fetch(ajaxUrl, {
                method: 'POST',
                body: formData
            })
                .then(res => res.json())
                .then(data => {
                    if (data.logged_in) {
                        if (languageWrapper) {
                            createLogoutButton(languageWrapper);
                            if (data.status !== 'not_active')
                                createManageMembershipButton(languageWrapper, data.status);

                        }
                        if (footerMenu) createLogoutButton(footerMenu);
                    } else {
                        const initialLoginUrl = data.login_url;
                        if (languageWrapper) createLoginButton(languageWrapper, initialLoginUrl, true);
                        if (footerMenu) createLoginButton(footerMenu, initialLoginUrl, false);

                        // Refresh OpenID URL every 110 seconds
                        setInterval(() => {
                            const refreshForm = new FormData();
                            refreshForm.append('action', 'get_openid_login_url');
                            refreshForm.append('redirect_to', window.location.href);

                            fetch(ajaxUrl, {
                                method: 'POST',
                                body: refreshForm
                            })
                                .then(res => res.text())
                                .then(newUrl => {
                                    document.querySelectorAll('.openid-login-link').forEach(link => link.href = newUrl);
                                })
                                .catch(err => console.error('Error refreshing login URL', err));
                        }, 110000);
                    }
                })
                .catch(err => console.error('Error fetching auth buttons:', err));

        });
    </script>

    <script>
        document.addEventListener("click", function (e) {
            const button = e.target.closest(".membership-portal");
            if (!button) return;

            e.preventDefault();

            const planId = button.getAttribute("data-cb-id");
            if (!planId) return;

            // Show loader + disable button
            button.classList.add("loading");
            button.disabled = true;

            const ajaxUrl = "https://www.vice.com/wp-admin/admin-ajax.php";

            fetch(ajaxUrl, {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body: new URLSearchParams({
                    action: "get_chargebee_plan",
                    plan_id: planId,
                }),
            })
                .then((res) => res.json())
                .then((response) => {
                    if (!response.success) {
                        console.error("Chargebee plan not found");
                        return;
                    }

                    // OPEN MODAL WITH API DATA
                    window.openPlanModal(button, {
                        planId: response.data.plan_id,
                        planName: response.data.plan_name,
                        priceValue: response.data.price,
                        purchaseType: response.data.purchase_type,
                    });
                })
                .catch((err) => {
                    console.error("Plan fetch error:", err);
                })
                .finally(() => {
                    // Remove loader + enable button
                    button.classList.remove("loading");
                    button.disabled = false;
                });
        });

    </script>
    <style>
        /* Button enters loading mode */
        .membership-portal.loading {
            color: transparent !important;
            /* hides button text */
            pointer-events: none;
        }

        /* Center spinner inside the button */
        .membership-portal.loading::after {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            width: 20px;
            height: 20px;
            margin-top: -10px;
            margin-left: -10px;
            border: 3px solid #fff;
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
        <script>
    const userdata = [] || {};
    const paymentStatus = localStorage.getItem('payment_status');
    const planId   = localStorage.getItem('cb_selected_plan_id_purchase_event');
    const planName = localStorage.getItem('cb_selected_plan_name');
    const planPrice = localStorage.getItem('cb_selected_plan_price');
    function isEmpty(obj) {
        return !obj || Object.keys(obj).length === 0;
    }

    setTimeout(() => {
        if (paymentStatus === 'succeeded') {
            const eventData = {
                content_ids: [planId],
                content_type: 'product',
                contents: [{
                    id: planId,
                    quantity: 1,
                    item_price: planPrice,
                    name: planName || 'VICE Subscription'
                }],
                currency: 'USD',
                value: planPrice,
                ...userdata
            };

            fbq('track', 'Purchase', eventData);

            // Clear only after successful event
            localStorage.removeItem('payment_status');
            localStorage.removeItem('cb_selected_plan_id_purchase_event');
            localStorage.removeItem('cb_selected_plan_name');
            localStorage.removeItem('cb_selected_plan_price');
        } 
    }, 3000); // 3 sec wait is enough (avoid 5 sec delay)
</script>

    
    <!-- Popup HTML -->
    <div id="unique-popup" class="unique-popup-container" style="display:none;">
        <form id="cb-customer-form">
            <div class="unique-popup-content">

                <div id="unique-close-btn" class="unique-close-btn">×</div>

                <div class="custom-classes">
                <img src="https://www.vice.com/wp-content/uploads/sites/2/2024/06/vice-logo_white@2x.png" alt="Logo" />


                    <div class="unique-popup-header">
                        <h2>Kill the ads for <br> just $2 a month</h2>
                    </div>

                    <div class="unique-popup-body">
                        <p>VICE membership also gives you access to our very best writing and exclusive new documentaries.</p>
                        <input type="hidden" name="ads-free-subscription-value" id="ads-free-subscription-value" value="2" />
                        <button class="join-now-button" id="join-now-button-popup" value="2"
                                data-plan-id="Digital-Monthly-USD-Monthly" data-purchase-type="plan">
                          Support for $2                        </button>
                        <di id="see-all-membership-plan" class="unique-continue-free-btn see-all-membership-plan">
                           See All Membership Plans
        </div>
                        <button id="unique-continue-free-btn" class="unique-continue-free-btn">
                            Or, continue for free
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {


        function showPopup() {
            const popup = document.getElementById("unique-popup");
            if (popup.style.display !== "flex") {
                popup.style.display = "flex";
            }
        }

        let exitIntentShown = false;

        function openExitModal() {
            if (!exitIntentShown) {
                exitIntentShown = true;
                showPopup();
            }
        }



            const VICE_POPUP_VISIT="vice_popup_visits";
            let popup = document.getElementById('unique-popup');
            let closeBtn = document.getElementById('unique-close-btn');
            let freeBtn = document.getElementById('unique-continue-free-btn');
            let join_now_button = document.getElementById('join-now-button-popup');
            closeBtn.addEventListener("click", hidePopup);
            freeBtn.addEventListener("click", hidePopup);
            join_now_button.addEventListener("click", hidePopup_to_membership);

            const visitLimit = 5;

            let visitCount = parseInt(localStorage.getItem(VICE_POPUP_VISIT) || "0");

            console.log('visit count here',visitCount);

            if(visitCount !== 0){
            visitCount++;
            }
            localStorage.setItem(VICE_POPUP_VISIT, visitCount);

            if (visitCount > visitLimit) {
                localStorage.setItem(VICE_POPUP_VISIT, 0);
            }

            function hidePopup(e) {
            e.preventDefault();
                    popup.style.display = "none";
                visitCount++;
                    localStorage.setItem('vice_popup_visits', visitCount);
            }
            function hidePopup_to_membership() {
                    popup.style.display = "none";
            }

            const existingBtn = document.querySelector('.see-all-membership-plan');

        if (existingBtn) {
            existingBtn.addEventListener('click', () => {
                const modal = document.querySelector('.free-modal-container');
                let popup = document.getElementById('unique-popup');
                if (modal) modal.style.display = 'block';
                if (typeof openModalFree === 'function') {
                    openModalFree();
                    popup.style.display = "none";
                }
            });
        }

        // Check if device is mobile
        const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth <= 768;

        // Desktop exit intent
        document.addEventListener("mouseout", (e) => {
            if (e.clientY <= 0 && !exitIntentShown && visitCount === 0) {
                openExitModal();
            }
        });

        // Mobile-only triggers
        if (isMobile) {
            let scrollDirection = 0;
            let lastScrollY = 0;

            window.addEventListener('scroll', () => {
                const currentScrollY = window.scrollY;
                scrollDirection = currentScrollY > lastScrollY ? 1 : -1;
                lastScrollY = currentScrollY;
            });

            document.addEventListener('visibilitychange', () => {
                if (document.hidden && !exitIntentShown && visitCount === 0) {
                    openExitModal();
                }
            });

            window.addEventListener('scroll', () => {
                if (scrollDirection === -1 && window.scrollY < 100 && !exitIntentShown && visitCount === 0) {
                    openExitModal();
                }
            });
        }




        });

        </script>

                    <!-- Thank-you modal  -->
                <div class="ty-modal-overlay ty-hidden"  id="tyModal">
                    <div class="ty-modal-box">
                        <div class="ty-modal-icon">
