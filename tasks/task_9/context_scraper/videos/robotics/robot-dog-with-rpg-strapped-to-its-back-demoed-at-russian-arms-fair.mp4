<script id="jquery-core-js-after">
(function() {
    // ✅ Check if simulation mode is active
    function shouldSimulate() {
        try {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('simulate_auth_timeout') === '1') return true;
            if (localStorage.getItem('simulate_auth_timeout') === 'true') return true;
        } catch (e) {}
        return false;
    }

    // ✅ Handle clicks on dynamically loaded Authentik login buttons
    document.addEventListener('click', function(e) {
        let t = e.target;
        while (t && t !== document) {
            if (t.tagName && t.tagName.toLowerCase() === 'a' && t.classList.contains('openid-login-link')) {
                localStorage.setItem('authentik_return_url', window.location.href);
                console.log('🔗 Authentik login clicked → return URL saved:', window.location.href);

                if (shouldSimulate()) {
                    e.preventDefault();
                    console.warn('⚠️ Simulating Authentik timeout...');
                    const errorUrl = '/wp-login.php?login-error=http_request_failed&message=' + encodeURIComponent('Simulated+timeout+for+testing');
                    window.location.href = errorUrl;
                }
                return;
            }
            t = t.parentNode;
        }
    }, false);

    // ✅ Allow toggling simulation from console
    window.toggleAuthSim = function(on) {
        if (on) {
            localStorage.setItem('simulate_auth_timeout', 'true');
            console.log('✅ Authentik timeout simulation ENABLED');
        } else {
            localStorage.removeItem('simulate_auth_timeout');
            console.log('❌ Authentik timeout simulation DISABLED');
        }
        return !!on;
    };
})();
//# sourceURL=jquery-core-js-after
</script>
