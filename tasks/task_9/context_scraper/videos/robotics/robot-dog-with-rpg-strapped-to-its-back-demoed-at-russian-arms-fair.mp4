document.addEventListener("DOMContentLoaded", function () {
  if (document.querySelector(".unlock-button")) {
    const pageKey = "reloaded_" + window.location.pathname;
    const now = Date.now();
    const expiry = 2 * 60 * 1000; // 2 minutes in ms

    const stored = sessionStorage.getItem(pageKey);

    if (!stored || now - JSON.parse(stored).time > expiry) {
      // ---- Your state change logic ----
      const url = new URL(window.location.href);
      url.searchParams.set("nocache", true);

      // Save timestamp
      sessionStorage.setItem(pageKey, JSON.stringify({ time: now }));

      // Reload with new URL
      window.location.href = url.toString();
    }
  }
});

  
</script>

