<script>
(function(){

localStorage.removeItem('is_login');
document.addEventListener("click", function(e){

    const link = e.target.closest(".openid-login-link");

    if(link){

        localStorage.setItem("vice_login_time", Date.now());
        localStorage.setItem("vice_login_redirect", window.location.href);

    }

});


(function quickRedirect(){

    const loginTime = localStorage.getItem("vice_login_time");
    const redirectUrl = localStorage.getItem("vice_login_redirect");

    if(!loginTime || !redirectUrl) return;

    const currentPath = window.location.pathname;
    const savedPath = new URL(redirectUrl).pathname;

    if(currentPath !== savedPath){

        const url = new URL(redirectUrl);
        url.searchParams.set("is_login", loginTime);

        localStorage.removeItem("vice_login_time");
        localStorage.removeItem("vice_login_redirect");

        window.location.replace(url.toString());

    }

})();

})();
</script><!-- /custom-ads entry #14 -->
