<script>
(function() {
    'use strict';

    console.clear();

    function clearViceCookie() {
        document.cookie = 'vice_login_id=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/; SameSite=Lax';
        document.cookie = 'vice_login_id=; expires=Thu, 01 Jan 1970 00:00:00 GMT; path=/; domain=' + window.location.hostname + '; SameSite=Lax';
    }

    function performLogout(e) {
        if (e) {
            e.preventDefault();
            e.stopImmediatePropagation();
        }


        clearViceCookie();

        const btn = this;
        btn.innerHTML = 'Logging out...';
        btn.disabled = true;

        setTimeout(() => {
            window.location.href = 'https://identity.vice.com/if/flow/vice-logout/';
        }, 400);
    }

    function attachLogoutHandler(button) {
        if (!button) return;

        // Clone to remove any previous handlers
        const newButton = button.cloneNode(true);
        button.parentNode.replaceChild(newButton, button);

        newButton.addEventListener('click', performLogout, true);

    }

    // Main function to find Logout button
    function findAndAttachLogout() {
        const container = document.querySelector('.wp-block-savage-platform-theme-language-picker');
        if (!container) return false;

        const logoutButton = Array.from(container.querySelectorAll('button')).find(btn => {
            const text = btn.textContent.trim().toLowerCase();
            return text === 'logout' || text.includes('log out') || text.includes('sign out');
        });

        if (logoutButton) {
            attachLogoutHandler(logoutButton);
            return true;
        }
        return false;
    }

    // === Initial Check ===
    if (findAndAttachLogout()) {
        return;
    }
    const observer = new MutationObserver(() => {
        if (findAndAttachLogout()) {
            observer.disconnect();
        }
    });

    observer.observe(document.body, {
        childList: true,
        subtree: true
    });

    setTimeout(() => {
        observer.disconnect();
        if (!document.querySelector('.wp-block-savage-platform-theme-language-picker button')) {
        }
    }, 30000);

})();
</script><!-- /custom-ads entry #13 -->
    <script>
    document.addEventListener('DOMContentLoaded', function () {

        const loginContainer = document.getElementById('cb-login-container');
        const manageBtn = document.getElementById('cb-manage-subscription-btn');

        // If neither UI exists on this page, do nothing.
        if (!loginContainer && !manageBtn) return;

        const formData = new FormData();
        formData.append('action', 'get_auth_buttons_json');
        formData.append('redirect_to', window.location.href);

        fetch('https://www.vice.com/wp-admin/admin-ajax.php', {
            method: 'POST',
            credentials: 'same-origin',
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (!data) {
                if (loginContainer) loginContainer.innerHTML = '<p>Please refresh to login.</p>';
                if (manageBtn) manageBtn.remove();
                return;
            }

            // ---------------------------
            // Case A: Logged out
            // ---------------------------
            if (!data.logged_in) {
                // Show login UI if placeholder exists
                if (loginContainer) {
                    const loginUrl = (data.login_url || '').trim();
                    if (!loginUrl) {
                        loginContainer.innerHTML = '<p>Please refresh to login.</p>';
                        return;
                    }

                    loginContainer.innerHTML = `
                        <p>Please log in to access your account.</p>
                        <button id="cb-login-btn" class="cb-login-btn cb-login-btn-style">Login</button>
                    `;

                    const btn = document.getElementById('cb-login-btn');
                    if (btn) {
                        btn.addEventListener('click', () => {
                            window.location.href = loginUrl;
                        });
                    }
                }

                // No manage subscription when logged out
                if (manageBtn) manageBtn.remove();
                return;
            }else{
                if(loginContainer){
                    location.reload();
                }
            }

            const status = data.status || '';
            let redirectUrl = '';

            if (status === 'cb_active') {
                redirectUrl = 'https://portal.vice.com/';
            } else if (status === 'grrm_active') {
                redirectUrl = 'https://payments.google.com/gp/w/home/subscriptionsandservices';
            }

            // Show/manage button only if we have a valid target
            if (manageBtn) {
                if (!redirectUrl) {
                    manageBtn.remove(); // or manageBtn.style.display = 'none';
                    return;
                }

                manageBtn.style.display = 'inline-block';
                manageBtn.addEventListener('click', function () {
                    window.location.href = redirectUrl;
                });
            }
        })
        .catch(() => {
            if (loginContainer) loginContainer.innerHTML = '<p>Unable to load login. Try again.</p>';
            if (manageBtn) manageBtn.remove();
        });

    });
    </script>
