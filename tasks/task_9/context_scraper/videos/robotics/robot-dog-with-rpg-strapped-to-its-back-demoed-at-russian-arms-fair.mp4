    <script>
            const loginLinks = document.querySelectorAll('.openid-login-link'); // selects all elements with this class
            if (loginLinks.length > 0) {
                loginLinks.forEach(link => {
                    link.addEventListener('click', function() {
                        const timestampId = Date.now();
                        localStorage.setItem('is_login', timestampId);
                    });
                });
            }

    </script>


<script>
        const currentUrl = window.location.href;

    let formData = new FormData();
    formData.append('action', 'get_auth_buttons_json');
    formData.append('redirect_to', currentUrl);
    const ajaxUrl = "https://www.vice.com/wp-admin/admin-ajax.php";
    fetch(ajaxUrl, {
        method: 'POST',
        body: formData
    })
    .then(res => res.json())
    .then(data => {
        if (!data.logged_in) {
            const wrapper = document.createElement("div");

            const paragraph = document.createElement("p");
            paragraph.className = "signin-text";
            paragraph.textContent = "Already have an account? ";

            const link = document.createElement("a");
            link.href = data.login_url;
            link.id = "openid-login-link";
            link.className = "link openid-login-link";

            const strong = document.createElement("strong");
            strong.textContent = "Sign in";

            // Build structure
            link.appendChild(strong);
            paragraph.appendChild(link);
            wrapper.appendChild(paragraph);

            // Add click event like in your second snippet
            link.addEventListener("click", (event) => {
                event.preventDefault(); // stop default navigation
                const timestampId = Date.now();
                localStorage.setItem("is_login", timestampId);
                // redirect manually if needed
                window.location.href = link.href;
            });

            // Insert into DOM
            const container = document.getElementById("login-container");
            container.innerHTML = ""; // clear previous content
            container.appendChild(wrapper);
        }
    })
    .catch(err => {
        console.error("Failed to fetch login button:", err);
    });
       document.addEventListener('DOMContentLoaded', () => {
        console.log('DOM fully loaded and parsed');
    const modal = document.querySelector('.free-modal-container');
    const openBtn = document.querySelector('.unlock-button');

    openModalFree = () => {
        if (!modal) {
            console.warn('Modal element not found');
            return;
        }
        modal.style.visibility = 'visible';
        modal.style.opacity = '1';
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        setTimeout(() => {
            document.addEventListener('click', handleOutsideClick);
        }, 0);
        document.addEventListener('keydown', handleEscape);
    };

    closeModal = () => {
        if (!modal) return;
        document.querySelector('.free-modal-container').style.display = 'none';
        modal.style.visibility = 'hidden';
        modal.style.opacity = '0';
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = 'auto';
        document.removeEventListener('click', handleOutsideClick);
        document.removeEventListener('keydown', handleEscape);
    };

    const handleEscape = (event) => {
        if (event.key === 'Escape') {
            closeModal();
        }
    };

    const handleOutsideClick = (event) => {
        if (!modal.contains(event.target) && !event.target.classList.contains('unlock-button')) {
            closeModal();
        }
    };

    if (openBtn) {
        openBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            openModal();
        });
    }
    });


</script>


