p = document.getElementById('outbrain-wrap');\n      let obEl = null;\n      if (obWrap) {\n        obEl = obWrap.querySelector('.OUTBRAIN');\n      }\n      if (obEl) {\n        const obObserver = new IntersectionObserver((entries) => {\n          if (entries[0].isIntersecting) {\n            // Set the data-src attribute as per Outbrain's requirement\n            const currentUrl = window.location.href;\n            obEl.setAttribute('data-src', currentUrl);\n\n            const script = document.createElement('script');\n            script.type = 'text/javascript';\n            script.async = true;\n            script.src = 'https://widgets.outbrain.com/outbrain.js';\n            document.head.appendChild(script);\n\n            obObserver.disconnect();\n          }\n        }, {\n          rootMargin: '500px'\n        });\n\n        obObserver.observe(obWrap);\n      }\n    })();\n  <\/script>\n</div>"},"displayProperties":{},"localEdits":{},"variants":{}}},{"collection":"features","type":"TDBAd/default","props":{"collection":"features","type":"TDBAd/default","id":"f0fXQ5dlQ4KU2Nt","name":"TDB Ad – 640x480","contentConfig":{"contentService":"","contentConfigValues":{},"inherit":true},"customFields":{"adType":"article_9","displayAdLabel":true,"lazyLoad":true,"reserveSpace":true,"maxRefreshCount":5,"refreshIntervalTimer":30,"adDisplay":"all","sectionPath":"content","shouldRefresh":true},"displayProperties":{},"localEdits":{},"variants":{}}},{"collection":"features","type":"TDBAd/default","props":{"collection":"features","type":"TDBAd/default","id":"f0fQXWbQIG3u2A6","name":"TDB Ad – footer 970x250","contentConfig":{"contentService":"","contentConfigValues":{},"inherit":true},"customFields":{"adType":"article_8","displayAdLabel":true,"lazyLoad":true,"reserveSpace":true,"maxRefreshCount":5,"refreshIntervalTimer":30,"sectionPath":"content","shouldRefresh":true},"displayProperties":{},"localEdits":{},"variants":{}}},{"collection":"features","type":"TDBAd/default","prop