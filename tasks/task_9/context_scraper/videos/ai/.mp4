                  if (pushlyId && window.sessionStorage) {
                    window.sessionStorage.setItem('pushlyId', pushlyId);
                  }
                });
              </script></div></div><script id="fusion-metadata" type="application/javascript">window.Fusion=window.Fusion||{};Fusion.arcSite="thedailybeast";Fusion.contextPath="/pf";Fusion.mxId="00000000";Fusion.deployment="374";Fusion.globalContent={"_id":"4HD54FLNZFC4FKXQMK75DPIRV4","additional_properties":{"has_published_copy":true,"is_published":true},"address":{},"canonical_website":"thedailybeast","comments":{"display_comments":true},"content_elements":[{"_id":"WL3JGXTCB5EQRBPTEPIXLWGLXI","additional_properties":{},"content":"President Donald Trump has been accused of sharing an AI-generated video showing a U.S. military airstrike targeting a boat allegedly carrying drugs from Venezuela.","type":"text"},{"_id":"YAVZWW36TBDPDPML4IK6YAWR5M","additional_properties":{},"content":"Freddy Nanez, Venezuela’s communications minister, suggested that the clip Trump <a href=\"https://truthsocial.com/@realDonaldTrump/posts/115136798909755892\" target=\"_self\" rel=\"\" title=\"https://truthsocial.com/@realDonaldTrump/posts/115136798909755892\">posted</a> on Truth Social, which is believed to show the moment that 11 people were killed during a strike in international waters, was fake and looked “cartoonish.”","type":"text"},{"_id":"ZTFJLM4GCZB2PMGJHYMEZUT4V4","additional_properties":{},"content":"Trump announced Tuesday that the U.S. military had hit the boat at a White House briefing that was the president’s first official public appearance in a week amid speculation about <a href=\"https://www.thedailybeast.com/trump79-cakes-bruised-hand-in-makeup-after-vanishing-for-days/\" target=\"_self\" rel=\"\" title=\"https://www.thedailybeast.com/trump79-cakes-bruised-hand-in-makeup-after-vanishing-for-days/\">the 79-year-old’s health.</a>","type":"text"},{"_id":"6DBRDRKKVZB7VEKKRH35SCZD7M","additional_properties":{"fullSizeResizeUrl":"/resizer/v2/6DBRDRKKVZB7VEKKRH35SCZD7M.jpg?auth=cd4ff2a7ebc6f1d0d96f25482256808ed551b4d6812d54b442202e938c3b83df","galleries":[],"ingestionMethod":"manual","mime_type":"image/jpeg","originalName":"boa.jpg","originalUrl":"https://cloudfront-us-east-1.images.arcpublishing.com/thedailybeast/6DBRDRKKVZB7VEKKRH35SCZD7M.jpg","proxyUrl":"/resizer/v2/6DBRDRKKVZB7VEKKRH35SCZD7M.jpg?auth=cd4ff2a7ebc6f1d0d96f25482256808ed551b4d6812d54b442202e938c3b83df","published":true,"resizeUrl":"/resizer/v2/6DBRDRKKVZB7VEKKRH35SCZD7M.jpg?auth=cd4ff2a7ebc6f1d0d96f25482256808ed551b4d6812d54b442202e938c3b83df","restricted":false,"thumbnailResizeUrl":"/resizer/v2/6DBRDRKKVZB7VEKKRH35SCZD7M.jpg?auth=cd4ff2a7ebc6f1d0d96f25482256808ed551b4d6812d54b442202e938c3b83df&width=300","version":1,"template_id":1305,"alt_text":"Black and white image of boat riding on the ocean.","link":""},"address":{},"alt_text":"Black and white image of boat riding on the ocean.","auth":{"1":"cd4ff2a7ebc6f1d0d96f25482256808ed551b4d6812d54b442202e938c3b83df"},"caption":"Donald Trump told reporters at the Oval Office the U.S. had “shot out a drug-carrying boat” coming from Venezuela.","created_date":"2025-09-03T12:30:44Z","credits":{"affiliation":[{"name":"Truth Social/Donald Trump","type":"author"}]},"height":1097,"image_type":"photograph","last_updated_date":"2025-09-03T14:58:53Z","licensable":false,"owner":{"id":"thedailybeast","sponsored":false},"source":{"additional_properties":{"editor":"photo center"},"edit_url":"","system":"photo center"},"subtitle":"","taxonomy":{"associated_tasks":[]},"type":"image","url":"https://cloudfront-us-east-1.images.arcpublishing.com/thedailybeast/6DBRDRKKVZB7VEKKRH35SCZD7M.jpg","version":"0.10.9","width":2193,"syndication":{},"creditIPTC":"Truth Social/Donald Trump"},{"_id":"C4YJDY3IVZHWZDNSKXKHAELDRE","additional_properties":{},"content":"Trump claimed the people targeted on the boat were members of the Tren de Aragua gang, which the U.S. designated a terrorist group in February. ","type":"text"},{"_id":"IIPA2NJ5NFEQTGI3H6C7S5QJS4","additional_properties":{},"content":"He also shared the video of the vessel being struck at sea, accompanied by the typically unhinged warning: “Please let this serve as notice to anybody even thinking about bringing drugs into the United States of America. BEWARE! Thank you for your attention to this matter!!!!!!!!!!!”","type":"text"},{"additional_properties":{"has_published_copy":true,"is_published":true,"publish_date":"2025-09-03T04:03:27.775Z"},"address":{},"canonical_website":"thedailybeast","comments":{"display_comments":true},"content_elements":[{"_id":"C3V5EEFU65BBZPSO2L52RTAWCQ","additional_properties":{},"content":"President Donald Trump has lashed out at the leaders of Russia, China, and North Korea in an angry Truth Social post accusing them of engaging in a plot against the U.S.","type":"text"},{"_id":"AKEQ4Q2ZRZGARPIYBDQ4PWE72Q","additional_properties":{},"content":"China’s Xi Jinping, Russian President Vladimir Putin, and North Korean leader Kim Jong Un are all in Beijing for China’s celebration of the 80th anniversary of Japan’s surrender in World War II.","type":"text"},{"_id":"5Q25GU524ZGXFNXE3G7SAJMAAE","additional_properties":{},"content":"Trump raged online as Xi was seen presiding over a vast military parade alongside world leaders in Tiananmen Square for China’s Victory Day celebrations, flexing his military might.","type":"text"},{"_id":"HFYFHREQ4BCTVDAYWBOK62XBKI","referent":{"id":"HFYFHREQ4BCTVDAYWBOK62XBKI","provider":"","referent_properties":{"additional_properties":{"alt_text":"Putin, Xi Jingping and Kim Jong-Un","link":""},"caption":"Chinese President Xi Jingping ensured Russia's Vladimir Putin and North Korea's Kimg Jong-Un were front and center beside him during the parade.","subtitle":"Military parade to mark the 80th anniversary of the end of World War Two, in Beijing"},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"R53H7OH7VFGUNLESGBK5TQ2WKQ","additional_properties":{},"content":"“The big question to be answered is whether or not President Xi of China will mention the massive amount of support and “blood” that The United States of America gave to China in order to help it to secure its FREEDOM from a very unfriendly foreign invader. Many Americans died in China’s quest for Victory and Glory,” Trump began his screed.","type":"text"},{"_id":"L6A5XCBBC5EXXNK42NDWE4DZBY","additional_properties":{},"content":"“I hope that they are rightfully Honored and Remembered for their Bravery and Sacrifice! May President Xi and the wonderful people of China have a great and lasting day of celebration,” he continued. ","type":"text"},{"_id":"Q7UYS6KBUNAXVBEXV3TLWHTQAQ","additional_properties":{},"content":"Trump ended his note with a direct accusation against the world leaders.","type":"text"},{"_id":"KN4OM5BQWVFSNFQ64OHOGXTJFM","additional_properties":{},"content":"“Please give my warmest regards to Vladimir Putin, and Kim Jong Un, as you conspire against The United States of America.”","type":"text"},{"_id":"FQNKXOIIAFDHPGEC6KRBPSMDVM","referent":{"id":"FQNKXOIIAFDHPGEC6KRBPSMDVM","provider":"","referent_properties":{},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"REAOUFQ3N5A7FA2JGDOWL7AHSA","additional_properties":{},"content":"His outraged post is a response to what some believe are China’s attempts to <a href=\"https://www.washingtonpost.com/world/2025/09/01/china-world-war-2-history/\" target=\"_self\" rel=\"\" title=\"https://www.washingtonpost.com/world/2025/09/01/china-world-war-2-history/\">rewrite the history</a> of World War II, particularly in a way that downplays U.S. involvement while emphasizing the role of the USSR.","type":"text"},{"_id":"HWM4HVPHERAWJHCK36WHFW3O3Y","additional_properties":{},"content":"The occasion is being marked by a massive military parade in the capital, including demonstrations of <a href=\"https://www.theguardian.com/world/live/2025/sep/03/china-victory-day-military-parade-80th-japan-surrender-live-updates-xi-jinping-putin-kim-jong-un-latest\" target=\"_self\" rel=\"\" title=\"https://www.theguardian.com/world/live/2025/sep/03/china-victory-day-military-parade-80th-japan-surrender-live-updates-xi-jinping-putin-kim-jong-un-latest\">new military hardware</a> from China. Among its introductions was the first intercontinental ballistic missile in years, stunning experts, according to <a href=\"https://edition.cnn.com/world/live-news/china-military-parade-xi-jinping-09-03-25-intl-hnk?t=1756868183556\" target=\"_self\" rel=\"\" title=\"https://edition.cnn.com/world/live-news/china-military-parade-xi-jinping-09-03-25-intl-hnk?t=1756868183556\">CNN</a>.","type":"text"},{"_id":"BZ33XETWFNFS3ABDJMRLC6S374","referent":{"id":"BZ33XETWFNFS3ABDJMRLC6S374","provider":"","referent_properties":{},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"5IQ23JLPTFHBJE7IWNTJU7WF3I","additional_properties":{},"content":"Ahead of the event, <i>The Washington Post </i>explained, several Chinese scholars, media outlets, and think tanks “have downplayed the significance of American assistance to China during World War II, casting the U.S. as a self-serving power then and now.”","type":"text"},{"_id":"DUIPATWM5RAQ5LFLXDE2I356SI","additional_properties":{},"content":"American historians disagree with these assertions, particularly those that suggest China would have won against Japan without U.S. involvement.","type":"text"},{"_id":"FCWTRQS4PJA3NBPPFOXXSH5TPQ","additional_properties":{},"content":"A professor at the Harvard Kennedy School explained to the <i>Post </i>that both countries needed each other.","type":"text"},{"_id":"MN45WJI6EJCUHKYF6PSY3P6B7M","additional_properties":{},"content":"“Without China’s continued resistance, the U.S. would have had a much bigger problem in the Asia-Pacific region, and without American financial assistance and military advice, China would have had it much harder to last till the end of the war,” Rana Mitter said. ","type":"text"},{"_id":"DACVLRAMJ5GY5MZHLXP72FM35A","referent":{"id":"DACVLRAMJ5GY5MZHLXP72FM35A","provider":"","referent_properties":{},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"CLHHD55IUZHUFLY5QHIQPEN3SA","additional_properties":{},"content":"Speaking to CNN’s Kaitlan Collins from Beijing, correspondent Ivan Watson emphasized that Xi was demonstrating how important Putin and Kim Jong Un were to him by placing them front and center.","type":"text"},{"_id":"UVEAV6ZQCVEN3JR4P5VE4Y64M4","additional_properties":{},"content":"He also noted that the leaders were clearly sending a message to the U.S., “calling out bullying” and urging leaders to oppose “Cold War mentality,” explaining, “These are all code words that he and the Russian president use to criticize international relations that they would argue have too long been dominated by the U.S.”","type":"text"},{"_id":"EN6VEANOBJATZFOTVQMDN237EI","embed":{"config":{"caption":"","videoCode":"<script src=\"https://cdn.jwplayer.com/players/HoNFx3A8-GLqh1UZa.js\"><\/script>"},"id":"custom_powerup_1756867363981","url":"/"},"subtype":"videoplayer","type":"custom_embed"},{"_id":"BZV2XICMEZAXTMPL3ZRTXOFMQM","additional_properties":{},"content":"After Trump’s attempted peace talks with Putin last month <a href=\"https://www.thedailybeast.com/donald-trump-admits-vladimir-putin-ceasefire-meeting-was-a-diplomatic-dud/\" target=\"_self\" rel=\"\" title=\"https://www.thedailybeast.com/donald-trump-admits-vladimir-putin-ceasefire-meeting-was-a-diplomatic-dud/\">failed to bear fruit</a>, the president is likely feeling threatened by the display of friendship between Putin and China.","type":"text"},{"_id":"FB2JRAPYSRCY3JDGTEA23OT7TM","additional_properties":{},"content":"Following meetings between the two leaders, Putin described Xi as a “<a href=\"https://www.theguardian.com/world/2025/sep/02/vladimir-putin-xi-jinping-russia-china-ties-kim-jong-un-beijing-parade\" target=\"_self\" rel=\"\" title=\"https://www.theguardian.com/world/2025/sep/02/vladimir-putin-xi-jinping-russia-china-ties-kim-jong-un-beijing-parade\">dear friend</a>,” telling him, “Our close communication reflects the strategic nature of Russia-China relations, which are at an unprecedentedly high level. We were always together then, and we remain together now.”","type":"text"},{"_id":"76MWP7GH7VDQ3F26PLLN2RUI4M","additional_properties":{},"content":"In a Tuesday interview on <i>The Scott Jennings Radio Show</i>, Trump said he was “very disappointed” in Putin and added that he was working on a plan regarding Russia’s war in Ukraine.","type":"text"},{"_id":"3H6WUZM2MNFSRKMWPF5ERM6BAA","referent":{"id":"https://x.com/ScottJenningsKY/status/1962938342892568719","provider":"https://publish.x.com/oembed?url=","referent_properties":{},"service":"oembed","type":"twitter"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"OGLE26TWG5FSBMRNFJELIKAP6I","additional_properties":{},"content":"“I am very disappointed in President Putin, I can say that, and we will be doing something to help people live,” the president said, without elaborating further.","type":"text"},{"_id":"VCQ2JPI3XBCCZPLKBMGULZVRNA","additional_properties":{},"content":"He also asserted that he was not concerned about China and Russia forming an alliance against the U.S., telling Jennings, “I am not concerned at all... We have the strongest military in the world, by far. They would never use their military on us. Believe me.vast","type":"text"}],"copyright":"editorial","created_date":"2025-09-03T01:37:54.221Z","credits":{"by":[{"referent":{"id":"Catherine-Bouris","provider":"","referent_properties":{},"type":"author"},"type":"reference","additional_properties":{"_do_not_inflate":true}}]},"description":{"basic":""},"display_date":"2025-09-03T03:30:55.863Z","distributor":{"category":"staff","name":"thedailybeast","subcategory":""},"first_publish_date":"2025-09-03T03:30:55.863Z","geo":{},"headlines":{"basic":"Trump Accuses Putin of Plot Against America in Bonkers Post","meta_title":"Trump Accuses Putin of Plot Against America in Bonkers Post","mobile":"Trump Accuses Putin of Plot Against America in Bonkers Post","native":"","print":"","table":"","tablet":"","web":"Trump Accuses Putin of Plot Against America in Bonkers Post"},"label":{"rubric":{"display":true,"text":"CONSPIRACY THEORY"}},"language":"","last_updated_date":"2025-09-03T07:04:00.692Z","owner":{"id":"thedailybeast","sponsored":false},"planning":{"scheduling":{},"story_length":{"character_count_actual":4076,"inch_count_actual":4,"line_count_actual":28,"word_count_actual":669}},"promo_items":{"1_1":{"_id":"5W47ZV6UFBEVPATOROPK6XCXPI","referent":{"id":"5W47ZV6UFBEVPATOROPK6XCXPI","provider":"","referent_properties":{},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},"basic":{"_id":"HULLKMTWAJAOVP4W2NR7SPLYME","referent":{"id":"HULLKMTWAJAOVP4W2NR7SPLYME","provider":"","referent_properties":{},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}}},"publish_date":"2025-09-03T07:04:00.552Z","related_content":{"basic":[],"clonedChildren":[],"clonedFromParent":[]},"revision":{"branch":"default","editions":["default"],"parent_id":"ROUCLHUX5JFPVBMVDZGWQYJ7KQ","published":true,"revision_id":"SYPNZCAKRBCY5BSFWCYUZJSIZI"},"source":{"name":"thedailybeast","source_type":"staff","system":"composer"},"subheadlines":{"basic":"The president fumed after the leaders of China, Russia, and North Korea appeared together in Beijing."},"subtype":"standard-tdb","taxonomy":{"tags":[{"_id":"2C5CKYH6XRDZFCYSIQP7OXKRZY","description":"Donald J. Trump","slug":"donald-j-trump","text":"Donald J. Trump"},{"_id":"QOTC7LQMMJHHHG6URGTKNTBE3U","description":"Vladimir Putin","slug":"vladimir-putin","text":"Vladimir Putin"},{"_id":"52VU3YUEF5HTFEIX54ZN5OKOVM","description":"Xi Jinping","slug":"xi-jinping","text":"Xi Jinping"},{"_id":"DDCS4WBVYFBN7AF4UVFJ6OUF6Q","description":"Russia","slug":"russia","text":"Russia"},{"_id":"DUXSLSMKXVE5HBT3UJVCBJRVRI","description":"China","slug":"china","text":"China"}],"sections":[{"type":"reference","referent":{"id":"/politics","type":"section","website":"thedailybeast"},"additional_properties":{"_do_not_inflate":true}}],"sites":[{"type":"reference","referent":{"id":"/politics","type":"section","website":"thedailybeast"},"additional_properties":{"_do_not_inflate":true}}],"primary_section":{"type":"reference","referent":{"id":"/politics","type":"section","website":"thedailybeast"},"additional_properties":{"_do_not_inflate":true}},"primary_site":{"type":"reference","referent":{"id":"/politics","type":"section","website":"thedailybeast"},"additional_properties":{"_do_not_inflate":true}}},"type":"story","version":"0.10.11","workflow":{"status_code":1},"_id":"QMEZC75JVZEUBH6Q43M2MORAIA","canonical_url":"/trump-accuses-putin-of-plot-against-america-in-bonkers-post/","websites":{"thedailybeast":{"website_url":"/trump-accuses-putin-of-plot-against-america-in-bonkers-post/","website_section":{"type":"reference","referent":{"id":"/politics","type":"section","website":"thedailybeast"},"additional_properties":{"_do_not_inflate":true}}}}},{"_id":"LZA35L2K4NDFXIUXZIGVEJUMLM","additional_properties":{},"content":"Nanez has now said the video, which was also shared online by several Trump administration officials, including Secretary of State Marco Rubio and Defense Secretary Pete Hegseth, of being “generated by AI.”","type":"text"},{"_id":"YY4S45AOW5GMDCR5MYER2FXIPI","additional_properties":{},"content":"“The video shows a ship being attacked and then exploding in a way that looks like a simplified, almost cartoonish animation, rather than a realistic depiction of an explosion,” Nanez <a href=\"https://www.instagram.com/p/DOHiirbEV6a/?hl=en&amp;img_index=1\" target=\"_self\" rel=\"\" title=\"https://www.instagram.com/p/DOHiirbEV6a/?hl=en&amp;img_index=1\">wrote</a> on social media.","type":"text"},{"_id":"V7KNPUQ62JBLZJTSWOI5XGXMRU","additional_properties":{},"content":"“The video contains motion artifacts and a lack of realistic detail, which is common in AI-generated videos. The water, in particular, looks very stylized and unnatural,” he added.","type":"text"},{"_id":"WJ4NU75IIRH55FWQTCKUHMQFZU","additional_properties":{"countryId":227,"fullSizeResizeUrl":"/resizer/v2/WJ4NU75IIRH55FWQTCKUHMQFZU.jpg?auth=88ae3d07864e785eb376413615aa59e1aeb1f8dd91829ca8a49576952c002e7f","galleries":[],"ingestionMethod":"manual","iptc_job_identifier":"776376809","iptc_source":"Getty Images North America","iptc_title":"Staff","mime_type":"image/jpeg","originalName":"heg.jpg","originalUrl":"https://cloudfront-us-east-1.images.arcpublishing.com/thedailybeast/WJ4NU75IIRH55FWQTCKUHMQFZU.jpg","proxyUrl":"/resizer/v2/WJ4NU75IIRH55FWQTCKUHMQFZU.jpg?auth=88ae3d07864e785eb376413615aa59e1aeb1f8dd91829ca8a49576952c002e7f","published":true,"resizeUrl":"/resizer/v2/WJ4NU75IIRH55FWQTCKUHMQFZU.jpg?auth=88ae3d07864e785eb376413615aa59e1aeb1f8dd91829ca8a49576952c002e7f","restricted":false,"takenOn":"2025-09-02T00:00:00Z","thumbnailResizeUrl":"/resizer/v2/WJ4NU75IIRH55FWQTCKUHMQFZU.jpg?auth=88ae3d07864e785eb376413615aa59e1aeb1f8dd91829ca8a49576952c002e7f&width=300","usage_instructions":"Not Released (NR) ","version":1,"template_id":1305,"alt_text":"Defense Secretary Pete Hegseth (R) looks on as U.S. President Donald Trump speaks in the Oval Office at the White House on September 02, 2025 in Washington, DC.","link":""},"address":{"locality":"Washington","region":"DC","country_name":"USA"},"alt_text":"Defense Secretary Pete Hegseth (R) looks on as U.S. President Donald Trump speaks in the Oval Office at the White House on September 02, 2025 in Washington, DC.","auth":{"1":"88ae3d07864e785eb376413615aa59e1aeb1f8dd91829ca8a49576952c002e7f"},"caption":"Defense Secretary Pete Hegseth also shared the clip on social media.","copyright":"2025 Getty Images","created_date":"2025-09-03T12:26:50Z","credits":{"affiliation":[{"name":"Alex Wong/Getty Images","type":"author"}],"by":[]},"height":2373,"image_type":"photograph","last_updated_date":"2025-09-03T14:58:53Z","licensable":false,"owner":{"id":"thedailybeast","sponsored":false},"slug":"2233406723","source":{"additional_properties":{"editor":"photo center"},"edit_url":"","system":"photo center"},"subtitle":"President Trump Makes Announcement In The Oval Office Of The White House","taxonomy":{"associated_tasks":[]},"type":"image","url":"https://cloudfront-us-east-1.images.arcpublishing.com/thedailybeast/WJ4NU75IIRH55FWQTCKUHMQFZU.jpg","version":"0.10.9","width":3559,"syndication":{},"creditIPTC":"Alex Wong/Getty Images","country_name":"United States"},{"_id":"RWWGD3TFH5GITJ3MVPOLUITZVM","additional_properties":{},"content":"News agency <a href=\"https://www.reuters.com/world/americas/us-military-kills-11-people-strike-alleged-drug-boat-venezuela-trump-says-2025-09-03/\" target=\"_self\" rel=\"\" title=\"https://www.reuters.com/world/americas/us-military-kills-11-people-strike-alleged-drug-boat-venezuela-trump-says-2025-09-03/\">Reuters</a> said it conducted independent checks on the video and found no evidence of manipulation. Reuters added that thorough verification “is an ongoing process” and that it will continue to review the footage as more information becomes available.","type":"text"},{"_id":"WXV6D5EXNRGBPG3Q6SYWPCDIZA","additional_properties":{},"content":"While not addressing the AI claims specifically, John Feeley, a former U.S. ambassador to Panama who worked in anti-drug operations in Latin America, said the video shared by the Trump administration does not align with standard Coast Guard protocol for stopping boats believed to be carrying narcotics.","type":"text"},{"_id":"WFGE7ORKVRAIPHPY3ZUDBXJRIY","additional_properties":{},"content":"“Everything is done to preserve life,” Feeley told <a href=\"https://www.wsj.com/politics/national-security/u-s-military-strikes-drug-vessel-from-venezuela-killing-11-19661cc9?mod=hp_lead_pos11\" target=\"_self\" rel=\"\" title=\"https://www.wsj.com/politics/national-security/u-s-military-strikes-drug-vessel-from-venezuela-killing-11-19661cc9?mod=hp_lead_pos11\"><i>The Wall Street Journal</i>.</a> “What we don’t do is just shoot up boats like Netflix likes to pretend. We can shoot in self-defense, but we rarely do that because most narcos just give up.”","type":"text"},{"_id":"67HWNXJSS5CCPPJLRT56XF5NBQ","additional_properties":{},"content":"The Pentagon referred a request for comment from the Daily Beast to the White House, who did not immediately respond.","type":"text"},{"_id":"5WUK7LSF6JDANNRTA54P6JEC6A","additional_properties":{"has_published_copy":true,"is_published":true,"publish_date":"2025-09-03T11:52:04.171Z"},"address":{},"canonical_website":"thedailybeast","comments":{"display_comments":true},"content_elements":[{"_id":"6EIXJN57ERH7RNF2DQIGEBSEXI","additional_properties":{},"content":"A federal appeals court shot down President Donald Trump’s claim that Venezuelan cartels have “invaded” the U.S., denying the administration’s bid to assume sweeping wartime deportation powers under the Alien Enemies Act. ","type":"text"},{"_id":"NHJP35ZOL5BBBC7COQ7SIEX2W4","additional_properties":{},"alignment":"left","content":"In a 2-1 ruling, the Fifth U.S. Circuit Court of Appeals held Tuesday that Trump cannot use the 1798 law to <a href=\"https://s3.documentcloud.org/documents/26081114/ca5-aea.pdf\" rel=\"\">deport Venezuelans</a> in Texas, Louisiana, and Mississippi. ","type":"text"},{"_id":"D5GA6ADEORAXXNFGFAUPLWCQOQ","referent":{"id":"D5GA6ADEORAXXNFGFAUPLWCQOQ","provider":"","type":"story"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"PS232DKK2ZBYLNZAK2FNPGDWR4","additional_properties":{},"alignment":"left","content":"The president had invoked the <a href=\"https://www.law.cornell.edu/uscode/text/50/21\" target=\"_self\" rel=\"\" title=\"https://www.law.cornell.edu/uscode/text/50/21\">Alien Enemies Act</a> in mid-March and abruptly sent about 250 Venezuelan migrants to El Salvador’s CECOT megaprison, leading to a <a href=\"https://www.thedailybeast.com/trump-celebrates-after-supreme-court-hands-him-a-victory-in-deportation-showdown/\" rel=\"\">flurry of legal challenges</a>. ","type":"text"},{"_id":"QTRLJRBK6VCEVEJMUY4SXOHPCM","additional_properties":{},"content":"The act allows the president to “remove” citizens of countries against which the U.S. has “declared war.” It also allows the removal of citizens from countries whose governments have perpetrated, attempted or threatened an “invasion or predatory incursion.” ","type":"text"},{"_id":"OVSIPUSJCVGHXDU5L527OYDHNI","referent":{"id":"OVSIPUSJCVGHXDU5L527OYDHNI","provider":"","referent_properties":{"additional_properties":{"alt_text":"Inmates at the Counter-Terrorism Confinement Centre (CECOT) mega-prison in El Salvador, where the Trump administration has been sending undocumented people.","link":""},"caption":"President Trump invoked the Alien Enemies Act in mid-March and sent about 250 Venezuelans to the Counter-Terrorism Confinement Centre (CECOT) megaprison in El Salvador.","subtitle":"EL SALVADOR-PRISON-GANGS-INMATES-CECOT"},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"VWWGA3CA5JC77FIIIOSB6JWKDE","additional_properties":{},"alignment":"left","content":"In his invocation, <a href=\"https://www.thedailybeast.com/trump-preparing-to-invoke-wartime-powers-to-speed-up-sluggish-deportations/\" rel=\"\">Trump wrote</a> that even though the U.S. is not at war with Venezuela, members of the Tren de Aragua gang have “invaded” the U.S. at the behest of President Nicolas Maduro—a claim that the Central Intelligence Agency and National Security Agency <a href=\"https://www.thedailybeast.com/cia-brutally-fact-checks-trumps-rationale-for-using-alien-enemies-act/\" rel=\"\">have flatly denied</a>. ","type":"text"},{"_id":"5SJM4PPTBNBTHEBS642CE7YGKU","additional_properties":{},"content":"In its ruling, the Fifth Circuit nevertheless assumed the validity of Trump’s “factual assertions” that the Maduro regime is controlling Tren de Aragua and that the gang is engaging in “mass illegal migration to the U.S.” to harm the country.","type":"text"},{"_id":"ZAIX6YNPAZHNVFTB7LYZ22NFVY","additional_properties":{},"content":"But, the court wrote, “A country’s encouraging its residents and citizens to enter this country illegally is not the modern-day equivalent of sending an armed, organized force to occupy, to disrupt, or to otherwise harm the United States.”","type":"text"},{"_id":"EKR3KYC55FEZLPEJ2E7KFGVUFM","additional_properties":{},"content":"Similarly, the judges assumed that the gang had indeed “used drug trafficking as a weapon against our citizens” as Trump claims. But again, attempts to weaken a country are not the same as an invasion, wrote Judge Leslie Southwick, who was appointed by President George W. Bush. ","type":"text"},{"_id":"AOFC4T2XWRFLPPSYPNF46UGLQ4","embed":{"config":{"caption":"","videoCode":"<script src=\"https://cdn.jwplayer.com/players/iXtmOR2T-GLqh1UZa.js\"><\/script>"},"id":"custom_powerup_1756896244586","url":"/"},"subtype":"videoplayer","type":"custom_embed"},{"_id":"LQC752YJVNGZBHAI4I4E6TGTRA","additional_properties":{},"content":"“We conclude that the findings do not support that an invasion or predatory incursion has occurred. We therefore conclude that petitioners are likely to prove that the AEA was improperly invoked,” Southwick wrote.","type":"text"},{"_id":"7R2T25AXEVGF5IICNVOUQ2YBD4","additional_properties":{},"content":"He was joined by Judge Irma Carrillo Ramirez, who was appointed by President Joe Biden, while Judge Andrew Oldham, a Trump appointee, dissented. ","type":"text"},{"_id":"VHNBOZFEXZDMXHOEQ5DYXJBSVA","additional_properties":{},"content":"The order grants a preliminary injunction blocking the deportations while the case continues to play out. The Trump administration could ask the entire Fifth Circuit to hear the case, instead of just the three-judge panel, or it could appeal to the Supreme Court. ","type":"text"},{"_id":"QZRT7HR6UNBB5PEZB5QQDU5NOY","additional_properties":{},"alignment":"left","content":"The Supreme Court justices have previously <a href=\"https://www.thedailybeast.com/trump-celebrates-after-supreme-court-hands-him-a-victory-in-deportation-showdown/\" rel=\"\">ruled on procedural issues</a> involving the myriad legal challenges to Trump’s use of the Alien Enemies Act, but they have yet to consider whether the invocation of the act itself was valid. ","type":"text"},{"_id":"OFV435NTNJGWVGU4LBDMHYGEEQ","referent":{"id":"OFV435NTNJGWVGU4LBDMHYGEEQ","provider":"","referent_properties":{},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"IUQ54VGD2JHVBOYXHXAZV34PJQ","additional_properties":{},"alignment":"left","content":"While some lower courts considering the issue have <a href=\"https://www.thedailybeast.com/trump-loses-it-at-judge-james-boasberg-appointed-to-signal-war-chat-lawsuit/\" rel=\"\">ruled against</a> the administration, Tuesday’s decision was the first time a federal appellate court has considered the legality of Trump’s proclamation. ","type":"text"},{"_id":"T5EBCAPC7ZAXRGAA5T7L3Y4VWA","additional_properties":{},"content":"In a statement, White House spokesperson Abigail Jackson told the Daily Beast that the president has the authority to “conduct national security operations in defense of the United States and to remove terrorists from the United States.” ","type":"text"},{"_id":"PXFX7IKTHNA7DPPRT7UKDOT6AU","additional_properties":{},"content":"“President Trump exercised this lawful authority and employed the Alien Enemies Act to remove enemies of the United States, including vicious TdA gang members, from the country,” she said. “Judge Oldham’s dissent provides a careful review of this authority, and we expect to be vindicated on the merits in this case.” ","type":"text"},{"_id":"TWQW4DIAFBFALFRSRQNEOITINE","additional_properties":{},"content":"Southwick wrote that the court was ruling with “humility” because prior to this year, the Alien Enemies Act had only been invoked three times in 250 years, most recently during World War II. ","type":"text"},{"_id":"N7UL2X3DVBF6XHWPKHQKLPHGKU","additional_properties":{},"content":"The Supreme Court has offered little guidance on how to interpret the statute, Southwick noted, and eventually, the Supreme Court will need to weigh in on Trump’s invocation of the act, whether in this case or in a different legal challenge to the proclamation. ","type":"text"},{"_id":"SB6O6SOYYBE4VC3A2UBFHUZ6TU","referent":{"id":"SB6O6SOYYBE4VC3A2UBFHUZ6TU","provider":"","type":"story"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"3QNZRU5AKJBNBDINMIHMYP2SKA","additional_properties":{},"content":"He emphasized that the injunction only applies to the use of the Alien Enemies Act and does not stop the administration of deporting migrants under other federal laws. ","type":"text"},{"_id":"MGHA37DBSRDGFAU6RI7VFYSI3A","additional_properties":{},"alignment":"left","content":"Conveniently, the same day that the panel held that the U.S. is not at war with Venezuela, Trump <a href=\"https://truthsocial.com/@realDonaldTrump/posts/115136798909755892\" rel=\"\">wrote on social media</a> that the U.S. had blown up a Venezuelan boat carrying 11 people. The boat was transporting illegal drugs in international waters when everyone on board was killed, the president said. ","type":"text"}],"copyright":"editorial","created_date":"2025-09-03T10:29:59.72Z","credits":{"by":[{"referent":{"id":"TR4TKAXMRJOCDDTBK5WNL6XI7Q","provider":"","referent_properties":{},"type":"author"},"type":"reference","additional_properties":{"_do_not_inflate":true}}]},"description":{"basic":""},"display_date":"2025-09-03T11:07:55.448Z","distributor":{"category":"staff","name":"thedailybeast","subcategory":""},"first_publish_date":"2025-09-03T11:07:55.448Z","geo":{},"headlines":{"basic":"Trump Hit With Humiliating Loss as Court Kills His Unlawful Deportation Plot","meta_title":"Trump Hit With Humiliating Loss as Court Kills His Unlawful Alien Enemies Act Deportation Plot","mobile":"Trump Hit With Humiliating Loss as Court Kills His Unlawful Deportation Plot","native":"","print":"","table":"","tablet":"","web":"Trump Hit With Humiliating Court Loss on Trademark Policy"},"label":{"rubric":{"display":true,"text":"SLAP IN THE FACE"}},"language":"","last_updated_date":"2025-09-08T08:58:26.553Z","owner":{"id":"thedailybeast","sponsored":false},"planning":{"scheduling":{},"story_length":{"character_count_actual":4406,"inch_count_actual":5,"line_count_actual":30,"word_count_actual":710}},"promo_items":{"1_1":{"_id":"LEY22BXBZBDCFPABFR2BJ3X6JA","referent":{"id":"LEY22BXBZBDCFPABFR2BJ3X6JA","provider":"","referent_properties":{"caption":""},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},"basic":{"_id":"FGPUUBE2P5GXXBLMKMCX3OLD4M","referent":{"id":"FGPUUBE2P5GXXBLMKMCX3OLD4M","provider":"","referent_properties":{"caption":""},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}}},"publish_date":"2025-09-08T08:58:26.45Z","related_content":{"basic":[{"_id":"D5GA6ADEORAXXNFGFAUPLWCQOQ","referent":{"id":"D5GA6ADEORAXXNFGFAUPLWCQOQ","provider":"","type":"story"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"SB6O6SOYYBE4VC3A2UBFHUZ6TU","referent":{"id":"SB6O6SOYYBE4VC3A2UBFHUZ6TU","provider":"","type":"story"},"type":"reference","additional_properties":{"_do_not_inflate":true}}],"clonedChildren":[],"clonedFromParent":[]},"revision":{"branch":"default","editions":["default"],"parent_id":"DVHI5SOAKFCWXNFUMMOFCMR7DA","published":true,"revision_id":"AJR57MFXMZFIPEE76HSHEQY72Q"},"source":{"name":"thedailybeast","source_type":"staff","system":"composer"},"subheadlines":{"basic":"The president has been blocked from using an 18th-century wartime law in his immigration crackdown."},"subtype":"standard-tdb","taxonomy":{"primary_section":{"referent":{"id":"/politics","type":"section","website":"thedailybeast"},"type":"reference","additional_properties":{"_do_not_inflate":true}},"primary_site":{"referent":{"id":"/politics","type":"site"},"type":"reference","additional_properties":{"_do_not_inflate":true}},"sections":[{"referent":{"id":"/politics","type":"section","website":"thedailybeast"},"type":"reference","additional_properties":{"_do_not_inflate":true}}],"sites":[{"referent":{"id":"/politics","type":"site"},"type":"reference","additional_properties":{"_do_not_inflate":true}}],"tags":[{"_id":"MDUSYT6TSFEXBDSN2VZQCTWJA4","description":"Donald J. Trump","slug":"donald-j-trump","text":"Donald J. Trump"},{"_id":"B2XH3H756ZH3XIHMB7ORSHBH4Q","description":"Venezuela","slug":"venezuela","text":"Venezuela"},{"_id":"627VTY5EPZHOZLOEZTL4PBS5VU","description":"Texas","slug":"texas","text":"Texas"},{"_id":"INHR7NHRWBFLNPZCHFEYUFC26M","description":"Louisiana","slug":"louisiana","text":"Louisiana"},{"_id":"DUZIA2XLWVC6FALEOKVZWAF67U","description":"Mississippi","slug":"mississippi","text":"Mississippi"}]},"type":"story","version":"0.10.11","websites":{"thedailybeast":{"website_section":{"referent":{"id":"/politics","type":"section","website":"thedailybeast"},"type":"reference","additional_properties":{"_do_not_inflate":true}},"website_url":"/trump-hit-with-humiliating-loss-as-court-blows-up-his-unlawful-alien-enemies-act-deportation-plot/"}},"workflow":{"status_code":1},"canonical_url":"/trump-hit-with-humiliating-loss-as-court-blows-up-his-unlawful-alien-enemies-act-deportation-plot/"},{"_id":"IRGD57BYYVGD7H2DNJPBESJRPY","additional_properties":{},"content":"Elsewhere on Tuesday, Trump suggested that bizarre viral footage showing items being launched from a White House window was “probably AI-generated,” claiming the building’s windows cannot be opened because they are all <a href=\"https://www.thedailybeast.com/trump-gives-bonkers-explanation-for-white-house-window-video/\" target=\"_self\" rel=\"\" title=\"https://www.thedailybeast.com/trump-gives-bonkers-explanation-for-white-house-window-video/\">“heavily armored and bullet-proofed.”</a>","type":"text"},{"_id":"3MBDN2KFYZDKPLTVIY6C6QWDYE","additional_properties":{},"content":"That statement directly contradicts an earlier explanation from the White House, which said the <a href=\"https://www.thedailybeast.com/white-house-reveals-why-mystery-objects-were-thrown-out-window/\" target=\"_self\" rel=\"\" title=\"https://www.thedailybeast.com/white-house-reveals-why-mystery-objects-were-thrown-out-window/\">video was genuine</a> and showed “a contractor who was doing regular maintenance while the President was gone.”","type":"text"},{"_id":"DRX4GFWD5JH5FO77N2EPL2WBUM","additional_properties":{},"content":"","type":"text"}],"copyright":"editorial","created_date":"2025-09-03T12:23:25.683Z","credits":{"by":[{"_id":"ewan-palmer","type":"author","version":"0.5.8","name":"Ewan Palmer","image":{"url":"https://author-service-images-prod-us-east-1.publishing.aws.arc.pub/thedailybeast/UUN5LNQHUVFILIPWJ3MSQZE5BE.jpg","version":"0.5.8","type":"image","auth":{"1":"2a035594114f8e721e406f274e4308fe37f9410a429262755d5c1d41d6573e00"}},"description":"Ewan Palmer is a reporter at The Daily Beast. He previously worked as a reporter for several years at Newsweek, where he predominantly covered U.S. politics. Prior to that, he covered British crime, politics, and current affairs for the International Business Times UK.","url":"","slug":"ewan-palmer","social_links":[{"site":"email","url":"ewan.palmer@thedailybeast.com"}],"socialLinks":[{"site":"email","url":"ewan.palmer@thedailybeast.com","deprecated":true,"deprecation_msg":"Please use social_links."}],"additional_properties":{"original":{"_id":"ewan-palmer","firstName":"Ewan","lastName":"Palmer","byline":"Ewan Palmer","image":"https://author-service-images-prod-us-east-1.publishing.aws.arc.pub/thedailybeast/UUN5LNQHUVFILIPWJ3MSQZE5BE.jpg","email":"ewan.palmer@thedailybeast.com","affiliations":"","education":[],"awards":[],"books":[],"podcasts":[],"bio_page":"","bio":"Ewan Palmer is a reporter at The Daily Beast. He previously worked as a reporter for several years at Newsweek, where he predominantly covered U.S. politics. Prior to that, he covered British crime, politics, and current affairs for the International Business Times UK.","longBio":"","slug":"ewan-palmer","native_app_rendering":false,"fuzzy_match":false,"contributor":false,"status":true,"last_updated_date":"2026-04-16T01:23:55.717Z","role":"Reporter","author_type":"Staff"}}}]},"description":{"basic":""},"display_date":"2025-09-03T14:58:53.786Z","distributor":{"category":"staff","name":"thedailybeast","subcategory":""},"first_publish_date":"2025-09-03T14:58:53.786Z","geo":{},"headlines":{"basic":"Trump Accused of Sharing Bogus Video of Deadly Drug Boat Strike","meta_title":"Donald Trump Accused of Sharing Bogus Video of Deadly Drug Boat Strike","mobile":"Trump Accused of Sharing Bogus Video of Deadly Drug Boat Strike","native":"","print":"","table":"","tablet":"","web":"Trump Accused of Sharing Bogus Video of Drug Boat Strike"},"label":{"rubric":{"display":true,"text":"STRIKING CLAIM"}},"language":"","last_updated_date":"2025-09-03T14:58:53.896Z","owner":{"id":"thedailybeast","sponsored":false},"planning":{"scheduling":{},"story_length":{"character_count_actual":3006,"inch_count_actual":3,"line_count_actual":21,"word_count_actual":475}},"promo_items":{"1_1":{"_id":"2WTSM3E4HBHKTNEDQX5TAXTZ3Q","additional_properties":{"countryId":227,"fullSizeResizeUrl":"/resizer/v2/2WTSM3E4HBHKTNEDQX5TAXTZ3Q.jpg?auth=8ef64da412fdbf88ca231d74032243c8211579a1f26a9e1ceeba4a97390af1e4","galleries":[],"ingestionMethod":"manual","iptc_job_identifier":"776376809","iptc_source":"AFP","iptc_title":"Contributor","keywords":["horizontal","politics","washington"],"mime_type":"image/jpeg","originalName":"ven.jpg","originalUrl":"https://cloudfront-us-east-1.images.arcpublishing.com/thedailybeast/2WTSM3E4HBHKTNEDQX5TAXTZ3Q.jpg","proxyUrl":"/resizer/v2/2WTSM3E4HBHKTNEDQX5TAXTZ3Q.jpg?auth=8ef64da412fdbf88ca231d74032243c8211579a1f26a9e1ceeba4a97390af1e4","published":true,"resizeUrl":"/resizer/v2/2WTSM3E4HBHKTNEDQX5TAXTZ3Q.jpg?auth=8ef64da412fdbf88ca231d74032243c8211579a1f26a9e1ceeba4a97390af1e4","restricted":false,"takenOn":"2025-09-02T00:00:00Z","thumbnailResizeUrl":"/resizer/v2/2WTSM3E4HBHKTNEDQX5TAXTZ3Q.jpg?auth=8ef64da412fdbf88ca231d74032243c8211579a1f26a9e1ceeba4a97390af1e4&width=300","usage_instructions":"Not Released (NR) ","version":2,"template_id":1305},"address":{"locality":"Washington","region":"District of Columbia","country_name":"USA"},"alt_text":"President Donald Trump speaks in the Oval Office of the White House in Washington, DC, on September 2, 2025.","auth":{"1":"8ef64da412fdbf88ca231d74032243c8211579a1f26a9e1ceeba4a97390af1e4"},"caption":"","copyright":"AFP or licensors","created_date":"2025-09-03T12:33:35Z","credits":{"affiliation":[{"name":"Saul Loeb/AFP via Getty Images","type":"author"}],"by":[]},"geo":{},"height":5504,"image_type":"photograph","last_updated_date":"2025-09-03T14:58:53Z","licensable":false,"owner":{"id":"thedailybeast","sponsored":false},"related_content":{"derivative_of":[{"referent":{"id":"B6B47CJSLFHBZE7ZMMS47UM4WM","type":"image"},"type":"reference"}]},"slug":"2232796739","source":{"additional_properties":{"editor":"photo center"},"edit_url":"","system":"photo center"},"subtitle":"","taxonomy":{"associated_tasks":[]},"type":"image","url":"https://cloudfront-us-east-1.images.arcpublishing.com/thedailybeast/2WTSM3E4HBHKTNEDQX5TAXTZ3Q.jpg","version":"0.10.9","width":5504,"syndication":{},"creditIPTC":"Saul Loeb/AFP via Getty Images","country_name":"United States"},"basic":{"_id":"VQ5SE7DN2JBTBNEKLRFET4MDV4","additional_properties":{"countryId":227,"fullSizeResizeUrl":"/resizer/v2/VQ5SE7DN2JBTBNEKLRFET4MDV4.jpg?auth=527039098abfc55ef58ab384da042b5226e1bbdc0ecc038d194e730d67366971","galleries":[],"ingestionMethod":"manual","iptc_job_identifier":"776376809","iptc_source":"AFP","iptc_title":"Contributor","keywords":["horizontal","politics","washington"],"mime_type":"image/jpeg","originalName":"ven.jpg","originalUrl":"https://cloudfront-us-east-1.images.arcpublishing.com/thedailybeast/VQ5SE7DN2JBTBNEKLRFET4MDV4.jpg","proxyUrl":"/resizer/v2/VQ5SE7DN2JBTBNEKLRFET4MDV4.jpg?auth=527039098abfc55ef58ab384da042b5226e1bbdc0ecc038d194e730d67366971","published":true,"resizeUrl":"/resizer/v2/VQ5SE7DN2JBTBNEKLRFET4MDV4.jpg?auth=527039098abfc55ef58ab384da042b5226e1bbdc0ecc038d194e730d67366971","restricted":false,"takenOn":"2025-09-02T00:00:00Z","thumbnailResizeUrl":"/resizer/v2/VQ5SE7DN2JBTBNEKLRFET4MDV4.jpg?auth=527039098abfc55ef58ab384da042b5226e1bbdc0ecc038d194e730d67366971&width=300","usage_instructions":"Not Released (NR) ","version":2,"template_id":1305},"address":{"locality":"Washington","region":"District of Columbia","country_name":"USA"},"alt_text":"President Donald Trump speaks in the Oval Office of the White House in Washington, DC, on September 2, 2025.","auth":{"1":"527039098abfc55ef58ab384da042b5226e1bbdc0ecc038d194e730d67366971"},"caption":"","copyright":"AFP or licensors","created_date":"2025-09-03T12:33:06Z","credits":{"affiliation":[{"name":"Saul Loeb/AFP via Getty Images","type":"author"}],"by":[]},"geo":{},"height":4644,"image_type":"photograph","last_updated_date":"2025-09-03T14:58:53Z","licensable":false,"owner":{"id":"thedailybeast","sponsored":false},"related_content":{"derivative_of":[{"referent":{"id":"B6B47CJSLFHBZE7ZMMS47UM4WM","type":"image"},"type":"reference"}]},"slug":"2232796739","source":{"additional_properties":{"editor":"photo center"},"edit_url":"","system":"photo center"},"subtitle":"","taxonomy":{"associated_tasks":[]},"type":"image","url":"https://cloudfront-us-east-1.images.arcpublishing.com/thedailybeast/VQ5SE7DN2JBTBNEKLRFET4MDV4.jpg","version":"0.10.9","width":8256,"syndication":{},"creditIPTC":"Saul Loeb/AFP via Getty Images","country_name":"United States"},"video":{"_id":"CGH6UYQ3MBFTFDAMO5D4M2IZ5I","embed":{"config":{"caption":"","videoCode":"<script src=\"https://cdn.jwplayer.com/players/DwIYeAeh-AjIcq1uW.js\"><\/script>"},"id":"custom_powerup_1756902761843","url":"/"},"subtype":"videoplayer","type":"custom_embed"}},"publish_date":"2025-09-03T14:58:53.786Z","related_content":{"basic":[{"_id":"5WUK7LSF6JDANNRTA54P6JEC6A","additional_properties":{"has_published_copy":true,"is_published":true,"publish_date":"2025-09-03T11:52:04.171Z"},"address":{},"canonical_website":"thedailybeast","comments":{"display_comments":true},"content_elements":[{"_id":"6EIXJN57ERH7RNF2DQIGEBSEXI","additional_properties":{},"content":"A federal appeals court shot down President Donald Trump’s claim that Venezuelan cartels have “invaded” the U.S., denying the administration’s bid to assume sweeping wartime deportation powers under the Alien Enemies Act. ","type":"text"},{"_id":"NHJP35ZOL5BBBC7COQ7SIEX2W4","additional_properties":{},"alignment":"left","content":"In a 2-1 ruling, the Fifth U.S. Circuit Court of Appeals held Tuesday that Trump cannot use the 1798 law to <a href=\"https://s3.documentcloud.org/documents/26081114/ca5-aea.pdf\" rel=\"\">deport Venezuelans</a> in Texas, Louisiana, and Mississippi. ","type":"text"},{"_id":"D5GA6ADEORAXXNFGFAUPLWCQOQ","referent":{"id":"D5GA6ADEORAXXNFGFAUPLWCQOQ","provider":"","type":"story"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"PS232DKK2ZBYLNZAK2FNPGDWR4","additional_properties":{},"alignment":"left","content":"The president had invoked the <a href=\"https://www.law.cornell.edu/uscode/text/50/21\" target=\"_self\" rel=\"\" title=\"https://www.law.cornell.edu/uscode/text/50/21\">Alien Enemies Act</a> in mid-March and abruptly sent about 250 Venezuelan migrants to El Salvador’s CECOT megaprison, leading to a <a href=\"https://www.thedailybeast.com/trump-celebrates-after-supreme-court-hands-him-a-victory-in-deportation-showdown/\" rel=\"\">flurry of legal challenges</a>. ","type":"text"},{"_id":"QTRLJRBK6VCEVEJMUY4SXOHPCM","additional_properties":{},"content":"The act allows the president to “remove” citizens of countries against which the U.S. has “declared war.” It also allows the removal of citizens from countries whose governments have perpetrated, attempted or threatened an “invasion or predatory incursion.” ","type":"text"},{"_id":"OVSIPUSJCVGHXDU5L527OYDHNI","referent":{"id":"OVSIPUSJCVGHXDU5L527OYDHNI","provider":"","referent_properties":{"additional_properties":{"alt_text":"Inmates at the Counter-Terrorism Confinement Centre (CECOT) mega-prison in El Salvador, where the Trump administration has been sending undocumented people.","link":""},"caption":"President Trump invoked the Alien Enemies Act in mid-March and sent about 250 Venezuelans to the Counter-Terrorism Confinement Centre (CECOT) megaprison in El Salvador.","subtitle":"EL SALVADOR-PRISON-GANGS-INMATES-CECOT"},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"VWWGA3CA5JC77FIIIOSB6JWKDE","additional_properties":{},"alignment":"left","content":"In his invocation, <a href=\"https://www.thedailybeast.com/trump-preparing-to-invoke-wartime-powers-to-speed-up-sluggish-deportations/\" rel=\"\">Trump wrote</a> that even though the U.S. is not at war with Venezuela, members of the Tren de Aragua gang have “invaded” the U.S. at the behest of President Nicolas Maduro—a claim that the Central Intelligence Agency and National Security Agency <a href=\"https://www.thedailybeast.com/cia-brutally-fact-checks-trumps-rationale-for-using-alien-enemies-act/\" rel=\"\">have flatly denied</a>. ","type":"text"},{"_id":"5SJM4PPTBNBTHEBS642CE7YGKU","additional_properties":{},"content":"In its ruling, the Fifth Circuit nevertheless assumed the validity of Trump’s “factual assertions” that the Maduro regime is controlling Tren de Aragua and that the gang is engaging in “mass illegal migration to the U.S.” to harm the country.","type":"text"},{"_id":"ZAIX6YNPAZHNVFTB7LYZ22NFVY","additional_properties":{},"content":"But, the court wrote, “A country’s encouraging its residents and citizens to enter this country illegally is not the modern-day equivalent of sending an armed, organized force to occupy, to disrupt, or to otherwise harm the United States.”","type":"text"},{"_id":"EKR3KYC55FEZLPEJ2E7KFGVUFM","additional_properties":{},"content":"Similarly, the judges assumed that the gang had indeed “used drug trafficking as a weapon against our citizens” as Trump claims. But again, attempts to weaken a country are not the same as an invasion, wrote Judge Leslie Southwick, who was appointed by President George W. Bush. ","type":"text"},{"_id":"AOFC4T2XWRFLPPSYPNF46UGLQ4","embed":{"config":{"caption":"","videoCode":"<script src=\"https://cdn.jwplayer.com/players/iXtmOR2T-GLqh1UZa.js\"><\/script>"},"id":"custom_powerup_1756896244586","url":"/"},"subtype":"videoplayer","type":"custom_embed"},{"_id":"LQC752YJVNGZBHAI4I4E6TGTRA","additional_properties":{},"content":"“We conclude that the findings do not support that an invasion or predatory incursion has occurred. We therefore conclude that petitioners are likely to prove that the AEA was improperly invoked,” Southwick wrote.","type":"text"},{"_id":"7R2T25AXEVGF5IICNVOUQ2YBD4","additional_properties":{},"content":"He was joined by Judge Irma Carrillo Ramirez, who was appointed by President Joe Biden, while Judge Andrew Oldham, a Trump appointee, dissented. ","type":"text"},{"_id":"VHNBOZFEXZDMXHOEQ5DYXJBSVA","additional_properties":{},"content":"The order grants a preliminary injunction blocking the deportations while the case continues to play out. The Trump administration could ask the entire Fifth Circuit to hear the case, instead of just the three-judge panel, or it could appeal to the Supreme Court. ","type":"text"},{"_id":"QZRT7HR6UNBB5PEZB5QQDU5NOY","additional_properties":{},"alignment":"left","content":"The Supreme Court justices have previously <a href=\"https://www.thedailybeast.com/trump-celebrates-after-supreme-court-hands-him-a-victory-in-deportation-showdown/\" rel=\"\">ruled on procedural issues</a> involving the myriad legal challenges to Trump’s use of the Alien Enemies Act, but they have yet to consider whether the invocation of the act itself was valid. ","type":"text"},{"_id":"OFV435NTNJGWVGU4LBDMHYGEEQ","referent":{"id":"OFV435NTNJGWVGU4LBDMHYGEEQ","provider":"","referent_properties":{},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"IUQ54VGD2JHVBOYXHXAZV34PJQ","additional_properties":{},"alignment":"left","content":"While some lower courts considering the issue have <a href=\"https://www.thedailybeast.com/trump-loses-it-at-judge-james-boasberg-appointed-to-signal-war-chat-lawsuit/\" rel=\"\">ruled against</a> the administration, Tuesday’s decision was the first time a federal appellate court has considered the legality of Trump’s proclamation. ","type":"text"},{"_id":"T5EBCAPC7ZAXRGAA5T7L3Y4VWA","additional_properties":{},"content":"In a statement, White House spokesperson Abigail Jackson told the Daily Beast that the president has the authority to “conduct national security operations in defense of the United States and to remove terrorists from the United States.” ","type":"text"},{"_id":"PXFX7IKTHNA7DPPRT7UKDOT6AU","additional_properties":{},"content":"“President Trump exercised this lawful authority and employed the Alien Enemies Act to remove enemies of the United States, including vicious TdA gang members, from the country,” she said. “Judge Oldham’s dissent provides a careful review of this authority, and we expect to be vindicated on the merits in this case.” ","type":"text"},{"_id":"TWQW4DIAFBFALFRSRQNEOITINE","additional_properties":{},"content":"Southwick wrote that the court was ruling with “humility” because prior to this year, the Alien Enemies Act had only been invoked three times in 250 years, most recently during World War II. ","type":"text"},{"_id":"N7UL2X3DVBF6XHWPKHQKLPHGKU","additional_properties":{},"content":"The Supreme Court has offered little guidance on how to interpret the statute, Southwick noted, and eventually, the Supreme Court will need to weigh in on Trump’s invocation of the act, whether in this case or in a different legal challenge to the proclamation. ","type":"text"},{"_id":"SB6O6SOYYBE4VC3A2UBFHUZ6TU","referent":{"id":"SB6O6SOYYBE4VC3A2UBFHUZ6TU","provider":"","type":"story"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"3QNZRU5AKJBNBDINMIHMYP2SKA","additional_properties":{},"content":"He emphasized that the injunction only applies to the use of the Alien Enemies Act and does not stop the administration of deporting migrants under other federal laws. ","type":"text"},{"_id":"MGHA37DBSRDGFAU6RI7VFYSI3A","additional_properties":{},"alignment":"left","content":"Conveniently, the same day that the panel held that the U.S. is not at war with Venezuela, Trump <a href=\"https://truthsocial.com/@realDonaldTrump/posts/115136798909755892\" rel=\"\">wrote on social media</a> that the U.S. had blown up a Venezuelan boat carrying 11 people. The boat was transporting illegal drugs in international waters when everyone on board was killed, the president said. ","type":"text"}],"copyright":"editorial","created_date":"2025-09-03T10:29:59.72Z","credits":{"by":[{"referent":{"id":"TR4TKAXMRJOCDDTBK5WNL6XI7Q","provider":"","referent_properties":{},"type":"author"},"type":"reference","additional_properties":{"_do_not_inflate":true}}]},"description":{"basic":""},"display_date":"2025-09-03T11:07:55.448Z","distributor":{"category":"staff","name":"thedailybeast","subcategory":""},"first_publish_date":"2025-09-03T11:07:55.448Z","geo":{},"headlines":{"basic":"Trump Hit With Humiliating Loss as Court Kills His Unlawful Deportation Plot","meta_title":"Trump Hit With Humiliating Loss as Court Kills His Unlawful Alien Enemies Act Deportation Plot","mobile":"Trump Hit With Humiliating Loss as Court Kills His Unlawful Deportation Plot","native":"","print":"","table":"","tablet":"","web":"Trump Hit With Humiliating Court Loss on Trademark Policy"},"label":{"rubric":{"display":true,"text":"SLAP IN THE FACE"}},"language":"","last_updated_date":"2025-09-08T08:58:26.553Z","owner":{"id":"thedailybeast","sponsored":false},"planning":{"scheduling":{},"story_length":{"character_count_actual":4406,"inch_count_actual":5,"line_count_actual":30,"word_count_actual":710}},"promo_items":{"1_1":{"_id":"LEY22BXBZBDCFPABFR2BJ3X6JA","referent":{"id":"LEY22BXBZBDCFPABFR2BJ3X6JA","provider":"","referent_properties":{"caption":""},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}},"basic":{"_id":"FGPUUBE2P5GXXBLMKMCX3OLD4M","referent":{"id":"FGPUUBE2P5GXXBLMKMCX3OLD4M","provider":"","referent_properties":{"caption":""},"type":"image"},"type":"reference","additional_properties":{"_do_not_inflate":true}}},"publish_date":"2025-09-08T08:58:26.45Z","related_content":{"basic":[{"_id":"D5GA6ADEORAXXNFGFAUPLWCQOQ","referent":{"id":"D5GA6ADEORAXXNFGFAUPLWCQOQ","provider":"","type":"story"},"type":"reference","additional_properties":{"_do_not_inflate":true}},{"_id":"SB6O6SOYYBE4VC3A2UBFHUZ6TU","referent":{"id":"SB6O6SOYYBE4VC3A2UBFHUZ6TU","provider":"","type":"story"},"type":"reference","additional_properties":{"_do_not_inflate":true}}],"clonedChildren":[],"clonedFromParent":[]},"revision":{"branch":"default","editions":["default"],"parent_id":"DVHI5SOAKFCWXNFUMMOFCMR7DA","published":true,"revision_id":"AJR57MFXMZFIPEE76HSHEQY72Q"},"source":{"name":"thedailybeast","source_type":"staff","system":"composer"},"subheadlines":{"basic":"The president has been blocked from using an 18th-century wartime law in his immigration crackdown."},"subtype":"standard-tdb","taxonomy":{"primary_section":{"referent":{"id":"/politics","type":"section","website":"thedailybeast"},"type":"reference","additional_properties":{"_do_not_inflate":true}},"primary_site":{"ref