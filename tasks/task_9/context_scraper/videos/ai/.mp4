  function cdm_getBlaizeCookies() {
      const blaize_session = /blaize_session=([^;]+)/g;
      const blaize_tracking_id = /blaize_tracking_id=([^;]+)/g;
      const sessions = cdm_getBlaizeCookie(blaize_session);
      const trackingIds = cdm_getBlaizeCookie(blaize_tracking_id);
      
      return { sessions, trackingIds };
    }

    function cdm_getBlaizeCookie(regex) {
      const matches = document.cookie.matchAll(regex);
      return Array.from(matches).map(match => match && match[1]);
    }

    function cdm_setBlaizeCookie(key, value, domain, expirationDate) {
      document.cookie = `${key}=${value}; path=/; domain=${domain}; expires=${expirationDate.toUTCString()}`;
    }

    function cdm_expireCookie(key, value, domain) {
      document.cookie = `${key}=${value}; path=/; domain=${domain}; max-age=0`;
    }

    function cdm_setAndExpireBlaizeCookie(name, value) {
      if (!value) {
        return console.log('not value provided for', name, value)
      }
      const oneYearFromNow = new Date(Date.now() + 365 * 24 * 60 * 60 * 1000);
      const wwwDomain = 'www.thedailybeast.com';
      const rootDomain = '.thedailybeast.com';

      cdm_expireCookie(name, value, wwwDomain);
      cdm_setBlaizeCookie(name, value, rootDomain, oneYearFromNow);
    }

    function cdm_updateBlaizeCookieDomain() {
      const { sessions, trackingIds } = cdm_getBlaizeCookies();
      
      const [trackingId] = trackingIds;
      const [sessionA, sessionB] = sessions;
      
      cdm_setAndExpireBlaizeCookie('blaize_tracking_id', trackingId);

      if (sessions.length === 1) {
        return cdm_setAndExpireBlaizeCookie('blaize_session', sessionA);
      }
      
      if (sessionA === sessionB) {
        return cdm_setAndExpireBlaizeCookie('blaize_session', sessionA);
      }

      // this area means theres 2 sessions with different values, not sure how to handle
      // cookieStore event listener will take care of it moving forward
    }

    cdm_updateBlaizeCookieDomain();

    let COOKIE_SESSION_FLAG = false;
    let COOKIE_TRACKING_FLAG = false;
    cookieStore.addEventListener('change', ({ changed, deleted }) => {
      
      // Log details of changed cookies
      for (const {name, value } of changed) {
        if (name === 'blaize_session' && value && !COOKIE_SESSION_FLAG) {
          COOKIE_SESSION_FLAG = true
          cdm_setAndExpireBlaizeCookie('blaize_session', value);

          // so that updating the cookie wont trigger another event
          setTimeout(() => {
            COOKIE_SESSION_FLAG = false;;
          }, 10);
        }

        if (name === 'blaize_tracking_id' && value && !COOKIE_TRACKING_FLAG) {
          COOKIE_TRACKING_FLAG = true
          cdm_setAndExpireBlaizeCookie('blaize_tracking_id', value);

          // so that updating the cookie wont trigger another event
          setTimeout(() => {
            COOKIE_TRACKING_FLAG = false;
          }, 10);
        }
      }

      for (const { name, value } of deleted) {
        if (name === 'blaize_session' && !COOKIE_SESSION_FLAG) {
          cdm_expireCookie('blaize_session', value, '.thedailybeast.com');
          setTimeout(() => {
            COOKIE_SESSION_FLAG = false;
          }, 10);
        }

        if (name === 'blaize_tracking_id' && !COOKIE_TRACKING_FLAG) {
          cdm_expireCookie('blaize_tracking_id', value, '.thedailybeast.com');

          setTimeout(() => {
            COOKIE_TRACKING_FLAG = false;
          }, 10);
